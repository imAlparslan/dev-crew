<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DevCrew.Desktop.App"
             xmlns:services="using:DevCrew.Desktop.Services">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Styles/Colors.xaml" />
                <ResourceInclude Source="/Styles/Responsive.xaml" />
                <ResourceInclude Source="/Styles/Fonts.xaml" />
                <ResourceInclude Source="/Styles/Converters.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.DataTemplates>
        <services:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme/>
                <StyleInclude Source="/Styles/DashboardTile.xaml" />
                <StyleInclude Source="/Styles/CommonStyles.xaml" />
                <StyleInclude Source="/Styles/CreateGuidStyles.xaml" />

        <Style Selector="Window">
            <Setter Property="FontFamily" Value="{DynamicResource FontDefault}"/>
                        <Setter Property="FontSize" Value="{DynamicResource FontSizeDefault}"/>
        </Style>

        <Style Selector="TabStrip">
            <Setter Property="Padding"
                    Value="0"/>
            <Setter Property="Margin"
                    Value="0"/>
        </Style>

        <Style Selector="TabStrip.top-tabs">
            <Setter Property="Background"
                    Value="Transparent"/>
        </Style>

        <Style Selector="TabStrip.top-tabs TabStripItem">
            <Setter Property="FontSize"
                    Value="{DynamicResource FontSizeMedium}"/>
            <Setter Property="Padding"
                    Value="16,10"/>
            <Setter Property="Margin"
                    Value="0,0,2,0"/>
            <Setter Property="Background"
                    Value="{StaticResource BrushTertiaryBackground}"/>
            <Setter Property="Foreground"
                    Value="{StaticResource BrushTertiaryText}"/>
            <Setter Property="BorderThickness"
                    Value="0,0,0,2"/>
            <Setter Property="BorderBrush"
                    Value="Transparent"/>
        </Style>

        <Style Selector="TabStrip.top-tabs TabStripItem:pointerover">
            <Setter Property="Background"
                    Value="{StaticResource BrushButtonHover}"/>
            <Setter Property="Foreground"
                    Value="{StaticResource BrushSecondaryText}"/>
        </Style>

        <Style Selector="TabStrip.top-tabs TabStripItem:selected">
            <Setter Property="Background"
                    Value="{StaticResource BrushSecondaryBackground}"/>
            <Setter Property="Foreground"
                    Value="{StaticResource BrushPrimaryText}"/>
            <Setter Property="BorderBrush"
                    Value="{StaticResource BrushAccent}"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
        </Style>

        <Style Selector="TabStrip.top-tabs TabStripItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="Background"/>
        </Style>

        <Style Selector="TabStrip.top-tabs TabStripItem:selected:pointerover">
            <Setter Property="Background"
                    Value="{StaticResource BrushSecondaryBackground}"/>
        </Style>

        <Style Selector="TabStrip.top-tabs TabStripItem Button">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity"
                            Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="TabStrip.top-tabs TabStripItem Button:pointerover">
            <Setter Property="Background"
                    Value="{StaticResource BrushDanger}"/>
            <Setter Property="Foreground"
                    Value="{StaticResource BrushPrimaryText}"/>
            <Setter Property="CornerRadius"
                    Value="4"/>
        </Style>

    </Application.Styles>
</Application>
