<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DevCrew.Desktop.Controls.CopyActionButton"
             x:Name="Root">
    <Button x:Name="PART_Button"
            Command="{Binding Command, ElementName=Root}"
            CommandParameter="{Binding CommandParameter, ElementName=Root}"
            Classes="IconActionButton AccentActionButton"
            Width="{DynamicResource IconButtonSize}"
            Height="{DynamicResource IconButtonSize}"
            Padding="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            ToolTip.Tip="{Binding ToolTipText, ElementName=Root}">
        <PathIcon Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z"
                  Width="{DynamicResource IconSize}"
                  Height="{DynamicResource IconSize}" />
    </Button>
</UserControl>
