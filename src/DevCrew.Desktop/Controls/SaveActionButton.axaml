<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DevCrew.Desktop.Controls.SaveActionButton"
             x:Name="Root">
        <Button Command="{Binding Command, ElementName=Root}"
            CommandParameter="{Binding CommandParameter, ElementName=Root}"
            Classes="IconActionButton"
            Width="{DynamicResource IconButtonSize}"
            Height="{DynamicResource IconButtonSize}"
            Padding="0"
            CornerRadius="8"
            BorderThickness="1"
            Background="#22C55E"
            BorderBrush="#16A34A"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            ToolTip.Tip="{Binding ToolTipText, ElementName=Root}">
        <PathIcon Data="M17 3H5C3.89 3 3 3.9 3 5V19C3 20.1 3.89 21 5 21H19C20.1 21 21 20.1 21 19V7L17 3M19 19H5V5H16.17L19 7.83V19M12 12C10.34 12 9 13.34 9 15S10.34 18 12 18 15 16.66 15 15 13.66 12 12 12M6 6H15V10H6V6Z"
                  Width="{DynamicResource IconSize}"
                  Height="{DynamicResource IconSize}" />
    </Button>
</UserControl>
