<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DevCrew.Desktop.Controls.BrowseActionButton"
             x:Name="Root">
    <Button Command="{Binding Command, ElementName=Root}"
            CommandParameter="{Binding CommandParameter, ElementName=Root}"
            Classes="IconActionButton AccentActionButton"
            Width="{DynamicResource IconButtonSize}"
            Height="{DynamicResource IconButtonSize}"
            Padding="0"
            CornerRadius="8"
            BorderThickness="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            ToolTip.Tip="{Binding ToolTipText, ElementName=Root}">
        <PathIcon Data="M6.1,10L4,18V8H21A2,2 0 0,0 19,6H12L10,4H4A2,2 0 0,0 2,6V18A2,2 0 0,0 4,20H19C19.9,20 20.7,19.4 20.9,18.5L23.2,10H6.1M19,18H6L7.6,12H20.6L19,18Z"
                  Width="{DynamicResource IconSize}"
                  Height="{DynamicResource IconSize}" />
    </Button>
</UserControl>