<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="using:DevCrew.Desktop.Converters">
    
    <!-- Reusable Converters -->
    
    <!-- Boolean to Opacity (0.0 to 1.0) -->
    <conv:BoolToDoubleConverter x:Key="BoolToOpacityConverter" />
    
    <!-- Boolean to Color -->
    <conv:BoolToColorConverter x:Key="BoolToColorConverter" />
    
    <!-- GUID View Converters -->
    <conv:BooleanToBrushConverter x:Key="GuidBackgroundConverter"
                                  TrueBrush="{StaticResource BrushAccent}"
                                  FalseBrush="{StaticResource BrushTertiaryBackground}" />
    <conv:BooleanToBrushConverter x:Key="GuidBorderConverter"
                                  TrueBrush="{StaticResource BrushAccentDark}"
                                  FalseBrush="{StaticResource BrushBorderSecondary}" />
    
    <!-- JWT Decoder View Converters -->
    <conv:BooleanToBrushConverter x:Key="SignatureValidBackgroundConverter"
                                  TrueBrush="{StaticResource BrushSuccess}"
                                  FalseBrush="{StaticResource BrushDanger}" />
    <conv:BooleanToBrushConverter x:Key="SignatureValidBorderConverter"
                                  TrueBrush="{StaticResource BrushSuccessDark}"
                                  FalseBrush="{StaticResource BrushDangerDark}" />
    
    <!-- Boolean String Converters -->
    <conv:BooleanToBrushConverter x:Key="SignatureStatusConverter"
                                  TrueString="✓ Geçerli"
                                  FalseString="✗ Geçersiz" />
    <conv:BooleanToBrushConverter x:Key="CopyStatusConverter"
                                  TrueString="✓ Kopyalandı"
                                  FalseString="📋 Kopyala" />
    
</ResourceDictionary>
