<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Font Families -->
    <FontFamily x:Key="FontMonospace">Consolas, Courier New, monospace</FontFamily>
    <FontFamily x:Key="FontDefault">Inter, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="FontHeading">Inter, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="FontButton">Inter, Segoe UI, sans-serif</FontFamily>
    
    <!-- Font Sizes -->
    <x:Double x:Key="FontSizeSmall">11</x:Double>
    <x:Double x:Key="FontSizeDefault">12</x:Double>
    <x:Double x:Key="FontSizeLabel">13</x:Double>
    <x:Double x:Key="FontSizeMedium">14</x:Double>
    <x:Double x:Key="FontSizeLarge">16</x:Double>
    <x:Double x:Key="FontSizeXLarge">32</x:Double>
    <x:Double x:Key="FontSizeHeading">20</x:Double>
    
    <!-- Font Weights -->
    <FontWeight x:Key="FontWeightNormal">Normal</FontWeight>
    <FontWeight x:Key="FontWeightSemiBold">SemiBold</FontWeight>
    <FontWeight x:Key="FontWeightBold">Bold</FontWeight>
    
</ResourceDictionary>
