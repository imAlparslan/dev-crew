<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DevCrew.Desktop.ViewModels"
             xmlns:conv="using:DevCrew.Desktop.Converters"
             x:Class="DevCrew.Desktop.Views.JwtDecoderView"
             x:DataType="vm:JwtDecoderViewModel">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="../Styles/Fonts.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <ScrollViewer>
        <Border Padding="{DynamicResource ResponsivePaddingMedium}" Background="{StaticResource BrushSecondaryBackground}">
            <Grid RowDefinitions="Auto,Auto,*" MaxWidth="900" HorizontalAlignment="Center">
                <!-- Header -->
                <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
                    <TextBlock Text="JWT Decoder"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrushPrimaryText}"
                               HorizontalAlignment="Center" />
                    
                    <TextBlock Text="JWT token'ınızı yapıştırın, otomatik olarak decode edilecek"
                               FontSize="14"
                               Foreground="{StaticResource BrushSecondaryText}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </StackPanel>

                <!-- Input Section -->
                <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto">
                    <!-- JWT Token Input -->
                    <Border Grid.Row="0"
                            Background="{StaticResource BrushTertiaryBackground}"
                            BorderBrush="{StaticResource BrushBorderSecondary}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Width="580"
                            Margin="0,0,0,12"
                            MinHeight="208"
                            Height="208"
                            MaxHeight="208"
                            HorizontalAlignment="Left">
                        <Grid RowDefinitions="Auto,120,Auto" MinHeight="184" Height="184" MaxHeight="184">
                            <TextBlock Grid.Row="0"
                                       Text="JWT Token"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushSecondaryText}"
                                       Margin="0,0,0,8" />
                            
                            <TextBox Grid.Row="1"
                                     Text="{Binding RawToken}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Width="556"
                                     Height="120"
                                     Padding="8"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     VerticalContentAlignment="Top"
                                     UseLayoutRounding="False"
                                     ClipToBounds="True"
                                     Background="{StaticResource BrushSecondaryBackground}"
                                     BorderBrush="{StaticResource BrushBorderSecondary}"
                                     BorderThickness="1"
                                     CornerRadius="4"
                                     Foreground="{StaticResource BrushPrimaryText}"
                                     FontFamily="{StaticResource FontMonospace}"
                                     FontSize="{StaticResource FontSizeSmall}"
                                     Watermark="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoxNTE2MjM5MDIyfQ..."
                                     SelectionBrush="{StaticResource BrushAccent}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
                            
                            <StackPanel Grid.Row="2"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        HorizontalAlignment="Right"
                                        Margin="0,8,0,0">
                                <Button Content="🔍 Decode"
                                        Command="{Binding DecodeTokenCommand}"
                                        Padding="12,6"
                                        Background="{StaticResource BrushAccent}"
                                        Foreground="{StaticResource BrushPrimaryText}"
                                        BorderBrush="{StaticResource BrushAccentDark}"
                                        CornerRadius="4"
                                        FontWeight="SemiBold" />
                                
                                <Button Content="✕ Clear"
                                        Command="{Binding ClearCommand}"
                                        Padding="12,6"
                                        Background="{StaticResource BrushDanger}"
                                        Foreground="{StaticResource BrushPrimaryText}"
                                        BorderBrush="{StaticResource BrushDangerDark}"
                                        CornerRadius="4" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Secret Input for Signature Validation -->
                    <Border Grid.Row="1"
                            Background="{StaticResource BrushTertiaryBackground}"
                            BorderThickness="2"
                            CornerRadius="6"
                            Padding="12"
                            Width="580"
                            Margin="0,0,0,12"
                            MinHeight="128"
                            Height="128"
                            MaxHeight="128"
                            HorizontalAlignment="Left"
                            IsVisible="{Binding DecodedHeader, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <Border.BorderBrush>
                            <Binding Path="IsSignatureValid" Converter="{StaticResource SignatureValidBorderConverter}" FallbackValue="{StaticResource BrushBorderSecondary}" />
                        </Border.BorderBrush>
                        <Grid RowDefinitions="Auto,Auto,Auto">
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                <TextBlock Grid.Column="0"
                                           Text="Secret Key (İmza Doğrulama)"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushSecondaryText}"
                                           VerticalAlignment="Center" />
                                
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Secret.Length, FallbackValue='0 karakter'}"
                                           FontSize="10"
                                           Foreground="{StaticResource BrushSecondaryText}"
                                           VerticalAlignment="Center">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} karakter">
                                            <Binding Path="Secret.Length" FallbackValue="0" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Grid>
                            
                            <Grid Grid.Row="1" ColumnDefinitions="Auto,*">
                                <Button Grid.Column="0"
                                        Content="👁️"
                                        Width="36"
                                        Height="36"
                                        Padding="0"
                                        Margin="0,0,4,0"
                                        Background="{StaticResource BrushTertiaryBackground}"
                                        BorderBrush="{StaticResource BrushBorderSecondary}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        ToolTip.Tip="Göster/Gizle"
                                        Command="{Binding ToggleSecretVisibilityCommand}" />
                                
                                <TextBox Grid.Column="1"
                                         Text="{Binding Secret}"
                                         PasswordChar="●"
                                         RevealPassword="{Binding IsSecretVisible}"
                                         Padding="8"
                                         Width="516"
                                         Height="36"
                                         TextWrapping="NoWrap"
                                         MaxLines="1"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Top"
                                         VerticalContentAlignment="Center"
                                         UseLayoutRounding="False"
                                         ClipToBounds="True"
                                         Background="{StaticResource BrushSecondaryBackground}"
                                         BorderBrush="{StaticResource BrushBorderSecondary}"
                                         BorderThickness="1"
                                         CornerRadius="4"
                                         Foreground="{StaticResource BrushPrimaryText}"
                                         FontFamily="{StaticResource FontMonospace}"
                                         Watermark="Secret key'inizi girin"
                                         SelectionBrush="{StaticResource BrushAccent}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled" />
                            </Grid>
                            
                            <Grid Grid.Row="2" Margin="0,8,0,0" ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4"
                                            IsVisible="{Binding IsSignatureValid, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <TextBlock Text="İmza Durumu: "
                                               FontSize="12"
                                               Foreground="{StaticResource BrushSecondaryText}"
                                               VerticalAlignment="Center" />
                                    <TextBlock FontSize="12"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding IsSignatureValid, Converter={StaticResource SignatureValidBackgroundConverter}}">
                                        <TextBlock.Text>
                                            <Binding Path="IsSignatureValid"
                                                     Converter="{StaticResource SignatureStatusConverter}" />
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                                
                                <Button Grid.Column="1"
                                        Content="🔐 Validate"
                                        Command="{Binding ValidateSignatureCommand}"
                                        Padding="12,6"
                                        Background="{StaticResource BrushAccent}"
                                        Foreground="{StaticResource BrushPrimaryText}"
                                        BorderBrush="{StaticResource BrushAccentDark}"
                                        CornerRadius="4" />
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Error Message -->
                    <Border Grid.Row="2"
                            Background="{StaticResource BrushDanger}"
                            BorderBrush="{StaticResource BrushDangerDark}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushPrimaryText}"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>

                <!-- Decoded Output Section -->
                <Grid Grid.Row="2"
                      RowDefinitions="Auto,Auto,Auto"
                      Margin="0,16,0,0"
                      IsVisible="{Binding DecodedHeader, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    
                    <!-- Token Info -->
                    <Border Grid.Row="0"
                            Background="{StaticResource BrushTertiaryBackground}"
                            BorderBrush="{StaticResource BrushBorderSecondary}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,12">
                        <Grid RowDefinitions="Auto,Auto">
                            <TextBlock Grid.Row="0"
                                       Text="Token Bilgileri"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushPrimaryText}"
                                       Margin="0,0,0,8" />
                            
                            <Grid Grid.Row="1" ColumnDefinitions="*,*">
                                <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                                    <TextBlock FontSize="11" Foreground="{StaticResource BrushSecondaryText}" TextWrapping="Wrap">
                                        <Run Text="Issuer: " />
                                        <Run Text="{Binding Issuer, FallbackValue='N/A'}" Foreground="{StaticResource BrushPrimaryText}" />
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="{StaticResource BrushSecondaryText}" TextWrapping="Wrap">
                                        <Run Text="Subject: " />
                                        <Run Text="{Binding Subject, FallbackValue='N/A'}" Foreground="{StaticResource BrushPrimaryText}" />
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="{StaticResource BrushSecondaryText}" TextWrapping="Wrap">
                                        <Run Text="Audience: " />
                                        <Run Text="{Binding Audience, FallbackValue='N/A'}" Foreground="{StaticResource BrushPrimaryText}" />
                                    </TextBlock>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock FontSize="11" Foreground="{StaticResource BrushSecondaryText}" TextWrapping="Wrap">
                                        <Run Text="Issued At: " />
                                        <Run Text="{Binding IssuedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}', FallbackValue='N/A'}" Foreground="{StaticResource BrushPrimaryText}" />
                                    </TextBlock>
                                    <TextBlock FontSize="11" TextWrapping="Wrap">
                                        <Run Text="Expires At: " Foreground="{StaticResource BrushSecondaryText}" />
                                        <Run Text="{Binding ExpiresAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}', FallbackValue='N/A'}" 
                                             Foreground="{StaticResource BrushPrimaryText}" />
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                    
                    <!-- Decoded Header -->
                    <Border Grid.Row="1"
                            Background="{StaticResource BrushTertiaryBackground}"
                            BorderBrush="{StaticResource BrushBorderSecondary}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,12">
                        <Grid RowDefinitions="Auto,Auto">
                            <Grid Grid.Row="0"
                                  ColumnDefinitions="*,Auto"
                                  Margin="0,0,0,8">
                                <TextBlock Grid.Column="0"
                                           Text="Decoded Header"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushPrimaryText}"
                                           VerticalAlignment="Center" />
                                
                                <Button Grid.Column="1"
                                        Command="{Binding CopyHeaderCommand}"
                                        Padding="8,4"
                                        Background="{StaticResource BrushAccent}"
                                        Foreground="{StaticResource BrushPrimaryText}"
                                        BorderBrush="{StaticResource BrushAccentDark}"
                                        CornerRadius="4"
                                        FontSize="11">
                                    <TextBlock>
                                        <TextBlock.Text>
                                            <Binding Path="IsHeaderCopied"
                                                     Converter="{StaticResource CopyStatusConverter}" />
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Button>
                            </Grid>
                            
                            <Border Grid.Row="1"
                                    Background="{StaticResource BrushSecondaryBackground}"
                                    BorderBrush="{StaticResource BrushBorderSecondary}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8">
                                <ScrollViewer MaxHeight="200">
                                    <TextBlock Text="{Binding DecodedHeader}"
                                               FontFamily="{StaticResource FontMonospace}"
                                               FontSize="{StaticResource FontSizeSmall}"
                                               Foreground="{StaticResource BrushPrimaryText}"
                                               TextWrapping="Wrap" />
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Border>
                    
                    <!-- Decoded Payload -->
                    <Border Grid.Row="2"
                            Background="{StaticResource BrushTertiaryBackground}"
                            BorderBrush="{StaticResource BrushBorderSecondary}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12">
                        <Grid RowDefinitions="Auto,Auto">
                            <Grid Grid.Row="0"
                                  ColumnDefinitions="*,Auto"
                                  Margin="0,0,0,8">
                                <TextBlock Grid.Column="0"
                                           Text="Decoded Payload"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushPrimaryText}"
                                           VerticalAlignment="Center" />
                                
                                <Button Grid.Column="1"
                                        Command="{Binding CopyPayloadCommand}"
                                        Padding="8,4"
                                        Background="{StaticResource BrushAccent}"
                                        Foreground="{StaticResource BrushPrimaryText}"
                                        BorderBrush="{StaticResource BrushAccentDark}"
                                        CornerRadius="4"
                                        FontSize="11">
                                    <TextBlock>
                                        <TextBlock.Text>
                                            <Binding Path="IsPayloadCopied"
                                                     Converter="{StaticResource CopyStatusConverter}" />
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Button>
                            </Grid>
                            
                            <Border Grid.Row="1"
                                    Background="{StaticResource BrushSecondaryBackground}"
                                    BorderBrush="{StaticResource BrushBorderSecondary}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8">
                                <ScrollViewer MaxHeight="300">
                                    <TextBlock Text="{Binding DecodedPayload}"
                                               FontFamily="{StaticResource FontMonospace}"
                                               FontSize="{StaticResource FontSizeSmall}"
                                               Foreground="{StaticResource BrushPrimaryText}"
                                               TextWrapping="Wrap" />
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </ScrollViewer>
</UserControl>
