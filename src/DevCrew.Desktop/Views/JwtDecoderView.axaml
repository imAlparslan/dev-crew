<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DevCrew.Desktop.ViewModels"
             xmlns:conv="using:DevCrew.Desktop.Converters"
             x:Class="DevCrew.Desktop.Views.JwtDecoderView"
             x:DataType="vm:JwtDecoderViewModel">
    
    <ScrollViewer>
        <Border Padding="{DynamicResource ResponsivePaddingMedium}" Background="{StaticResource BrushSecondaryBackground}">
            <Grid RowDefinitions="Auto,Auto,*" HorizontalAlignment="Stretch">
                <!-- Header -->
                <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
                    <TextBlock Text="{Binding [jwtdecoder.title], Source={StaticResource Loc}}"
                               FontSize="{DynamicResource FontSizeHeading}"
                               FontFamily="{DynamicResource FontHeading}"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrushPrimaryText}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Input Section -->
                <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto">
                    <!-- JWT Token Input -->
                    <Border Grid.Row="0"
                            Background="{StaticResource BrushTertiaryBackground}"
                            BorderBrush="{StaticResource BrushBorderSecondary}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,12"
                            MinHeight="208"
                            Height="208"
                            MaxHeight="208"
                            HorizontalAlignment="Stretch">
                        <Grid RowDefinitions="Auto,120,Auto" MinHeight="184" Height="184" MaxHeight="184">
                            <TextBlock Grid.Row="0"
                                       Text="{Binding [jwtdecoder.token_title], Source={StaticResource Loc}}"
                                       FontSize="{DynamicResource FontSizeDefault}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushSecondaryText}"
                                       Margin="0,0,0,8" />
                            
                            <TextBox Grid.Row="1"
                                     Text="{Binding RawToken}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Height="120"
                                     Padding="8"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     VerticalContentAlignment="Top"
                                     Classes="MonospaceInputTextBox"
                                     FontSize="{DynamicResource FontSizeSmall}"
                                     Watermark="{Binding [jwtdecoder.token_watermark], Source={StaticResource Loc}}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
                            
                            <StackPanel Grid.Row="2"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        HorizontalAlignment="Right"
                                        Margin="0,8,0,0">
                                <Button Content="{Binding [jwtdecoder.decode], Source={StaticResource Loc}}"
                                        Command="{Binding DecodeTokenCommand}"
                                    Classes="ActionButton AccentActionButton"
                                    FontWeight="SemiBold" />
                                
                                <Button Content="{Binding [jwtdecoder.clear], Source={StaticResource Loc}}"
                                        Command="{Binding ClearCommand}"
                                    Classes="ActionButton DangerActionButton" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Secret Input for Signature Validation -->
                    <Border Grid.Row="1"
                            Background="{StaticResource BrushTertiaryBackground}"
                            BorderThickness="2"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,12"
                            MinHeight="128"
                            MaxHeight="200"
                            HorizontalAlignment="Stretch"
                            IsVisible="{Binding DecodedHeader, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <Border.BorderBrush>
                            <Binding Path="IsSignatureValid" Converter="{StaticResource SignatureValidBorderConverter}" FallbackValue="{StaticResource BrushBorderSecondary}" />
                        </Border.BorderBrush>
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                <!-- HMAC Title -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [jwtdecoder.secret_title], Source={StaticResource Loc}}"
                                           FontSize="{DynamicResource FontSizeDefault}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushSecondaryText}"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding !IsRsaAlgorithm}" />
                                
                                <!-- RSA Title -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [jwtdecoder.public_key_title], Source={StaticResource Loc}}"
                                           FontSize="{DynamicResource FontSizeDefault}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushSecondaryText}"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding IsRsaAlgorithm}" />
                            </Grid>
                            
                            <!-- HMAC Secret Key -->
                            <Grid Grid.Row="1" ColumnDefinitions="Auto,*" IsVisible="{Binding !IsRsaAlgorithm}">
                                <Button Grid.Column="0"
                                        Content="👁️"
                                        Width="36"
                                        Height="36"
                                        Padding="0"
                                        Margin="0,0,4,0"
                                    Classes="NeutralActionButton"
                                        ToolTip.Tip="{Binding [jwtdecoder.toggle_secret], Source={StaticResource Loc}}"
                                        Command="{Binding ToggleSecretVisibilityCommand}" />
                                
                                <TextBox Grid.Column="1"
                                         Text="{Binding Secret}"
                                         PasswordChar="●"
                                         RevealPassword="{Binding IsSecretVisible}"
                                         Padding="8"
                                         Height="36"
                                         TextWrapping="NoWrap"
                                         MaxLines="1"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Top"
                                         VerticalContentAlignment="Center"
                                         Classes="MonospaceInputTextBox"
                                         Watermark="{Binding [jwtdecoder.secret_watermark], Source={StaticResource Loc}}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled" />
                            </Grid>
                            
                            <!-- RSA Public Key -->
                            <TextBox Grid.Row="2"
                                     Text="{Binding PublicKey}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Padding="8"
                                     MinHeight="60"
                                     MaxHeight="100"
                                     HorizontalAlignment="Stretch"
                                     Classes="MonospaceInputTextBox"
                                     FontSize="{DynamicResource FontSizeSmall}"
                                     Watermark="{Binding [jwtdecoder.public_key_watermark], Source={StaticResource Loc}}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     IsVisible="{Binding IsRsaAlgorithm}" />
                            
                            <Grid Grid.Row="3" Margin="0,8,0,0" ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4"
                                            IsVisible="{Binding IsSignatureValid, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <TextBlock Text="{Binding [jwtdecoder.signature_status], Source={StaticResource Loc}}"
                                               FontSize="{DynamicResource FontSizeDefault}"
                                               Foreground="{StaticResource BrushSecondaryText}"
                                               VerticalAlignment="Center" />
                                    <TextBlock FontSize="{DynamicResource FontSizeDefault}"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding IsSignatureValid, Converter={StaticResource SignatureValidBackgroundConverter}}">
                                        <TextBlock.Text>
                                            <Binding Path="IsSignatureValid"
                                                     Converter="{StaticResource SignatureStatusConverter}" />
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                                
                                <Button Grid.Column="1"
                                    Content="{Binding [jwtdecoder.validate], Source={StaticResource Loc}}"
                                        Command="{Binding ValidateSignatureCommand}"
                                    Classes="ActionButton AccentActionButton" />
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Error Message -->
                    <Border Grid.Row="2"
                            Background="{StaticResource BrushDanger}"
                            BorderBrush="{StaticResource BrushDangerDark}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="{DynamicResource FontSizeDefault}"
                                   Foreground="{StaticResource BrushPrimaryText}"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>

                <!-- Decoded Output Section -->
                <Grid Grid.Row="2"
                      RowDefinitions="Auto,Auto,Auto"
                      Margin="0,16,0,0"
                      IsVisible="{Binding DecodedHeader, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    
                    <!-- Token Info -->
                    <Border Grid.Row="0"
                            Background="{StaticResource BrushTertiaryBackground}"
                            BorderBrush="{StaticResource BrushBorderSecondary}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,12">
                        <Grid RowDefinitions="Auto,Auto">
                            <TextBlock Grid.Row="0"
                                       Text="{Binding [jwtdecoder.token_info], Source={StaticResource Loc}}"
                                       FontSize="{DynamicResource FontSizeMedium}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushPrimaryText}"
                                       Margin="0,0,0,8" />
                            
                            <Grid Grid.Row="1" ColumnDefinitions="*,*">
                                <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                                    <TextBlock FontSize="{DynamicResource FontSizeSmall}" Foreground="{StaticResource BrushSecondaryText}" TextWrapping="Wrap">
                                        <Run Text="{Binding [jwtdecoder.issuer], Source={StaticResource Loc}}" />
                                        <Run Text="{Binding Issuer, FallbackValue='N/A'}" Foreground="{StaticResource BrushPrimaryText}" />
                                    </TextBlock>
                                    <TextBlock FontSize="{DynamicResource FontSizeSmall}" Foreground="{StaticResource BrushSecondaryText}" TextWrapping="Wrap">
                                        <Run Text="{Binding [jwtdecoder.subject], Source={StaticResource Loc}}" />
                                        <Run Text="{Binding Subject, FallbackValue='N/A'}" Foreground="{StaticResource BrushPrimaryText}" />
                                    </TextBlock>
                                    <TextBlock FontSize="{DynamicResource FontSizeSmall}" Foreground="{StaticResource BrushSecondaryText}" TextWrapping="Wrap">
                                        <Run Text="{Binding [jwtdecoder.audience], Source={StaticResource Loc}}" />
                                        <Run Text="{Binding Audience, FallbackValue='N/A'}" Foreground="{StaticResource BrushPrimaryText}" />
                                    </TextBlock>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock FontSize="{DynamicResource FontSizeSmall}" Foreground="{StaticResource BrushSecondaryText}" TextWrapping="Wrap">
                                        <Run Text="{Binding [jwtdecoder.issued_at], Source={StaticResource Loc}}" />
                                        <Run Text="{Binding IssuedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}', FallbackValue='N/A'}" Foreground="{StaticResource BrushPrimaryText}" />
                                    </TextBlock>
                                    <TextBlock FontSize="{DynamicResource FontSizeSmall}" TextWrapping="Wrap">
                                        <Run Text="{Binding [jwtdecoder.expires_at], Source={StaticResource Loc}}" Foreground="{StaticResource BrushSecondaryText}" />
                                        <Run Text="{Binding ExpiresAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}', FallbackValue='N/A'}" 
                                             Foreground="{StaticResource BrushPrimaryText}" />
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                    
                    <!-- Decoded Header -->
                    <Border Grid.Row="1"
                            Background="{StaticResource BrushTertiaryBackground}"
                            BorderBrush="{StaticResource BrushBorderSecondary}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,12">
                        <Grid RowDefinitions="Auto,Auto">
                            <Grid Grid.Row="0"
                                  ColumnDefinitions="*,Auto"
                                  Margin="0,0,0,8">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [jwtdecoder.decoded_header], Source={StaticResource Loc}}"
                                           FontSize="{DynamicResource FontSizeMedium}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushPrimaryText}"
                                           VerticalAlignment="Center" />
                                
                                <Button Grid.Column="1"
                                        Command="{Binding CopyHeaderCommand}"
                                    Classes="ActionButtonCompact AccentActionButton">
                                    <TextBlock>
                                        <TextBlock.Text>
                                            <Binding Path="IsHeaderCopied"
                                                     Converter="{StaticResource CopyStatusConverter}" />
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Button>
                            </Grid>
                            
                            <Border Grid.Row="1"
                                    Background="{StaticResource BrushSecondaryBackground}"
                                    BorderBrush="{StaticResource BrushBorderSecondary}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8">
                                <ScrollViewer MaxHeight="200">
                                    <TextBlock Text="{Binding DecodedHeader}"
                                               FontFamily="{DynamicResource FontMonospace}"
                                               FontSize="{DynamicResource FontSizeSmall}"
                                               Foreground="{StaticResource BrushPrimaryText}"
                                               TextWrapping="Wrap" />
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Border>
                    
                    <!-- Decoded Payload -->
                    <Border Grid.Row="2"
                            Background="{StaticResource BrushTertiaryBackground}"
                            BorderBrush="{StaticResource BrushBorderSecondary}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12">
                        <Grid RowDefinitions="Auto,Auto">
                            <Grid Grid.Row="0"
                                  ColumnDefinitions="*,Auto"
                                  Margin="0,0,0,8">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [jwtdecoder.decoded_payload], Source={StaticResource Loc}}"
                                           FontSize="{DynamicResource FontSizeMedium}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushPrimaryText}"
                                           VerticalAlignment="Center" />
                                
                                <Button Grid.Column="1"
                                        Command="{Binding CopyPayloadCommand}"
                                    Classes="ActionButtonCompact AccentActionButton">
                                    <TextBlock>
                                        <TextBlock.Text>
                                            <Binding Path="IsPayloadCopied"
                                                     Converter="{StaticResource CopyStatusConverter}" />
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Button>
                            </Grid>
                            
                            <Border Grid.Row="1"
                                    Background="{StaticResource BrushSecondaryBackground}"
                                    BorderBrush="{StaticResource BrushBorderSecondary}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8">
                                <ScrollViewer MaxHeight="300">
                                    <TextBlock Text="{Binding DecodedPayload}"
                                               FontFamily="{DynamicResource FontMonospace}"
                                               FontSize="{DynamicResource FontSizeSmall}"
                                               Foreground="{StaticResource BrushPrimaryText}"
                                               TextWrapping="Wrap" />
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </ScrollViewer>
</UserControl>
