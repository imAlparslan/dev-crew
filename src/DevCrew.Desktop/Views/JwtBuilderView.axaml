<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DevCrew.Desktop.ViewModels"
             xmlns:controls="using:DevCrew.Desktop.Controls"
             x:Class="DevCrew.Desktop.Views.JwtBuilderView"
             x:DataType="vm:JwtBuilderViewModel">
    
    <ScrollViewer>
        <Border Padding="{DynamicResource ResponsivePaddingMedium}" Background="{StaticResource BrushSecondaryBackground}">
            <StackPanel Spacing="12" HorizontalAlignment="Stretch">
                <!-- Header -->
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding [jwtbuilder.title], Source={StaticResource Loc}}"
                               FontSize="{DynamicResource FontSizeHeading}"
                               FontFamily="{DynamicResource FontHeading}"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrushPrimaryText}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Algorithm and Secret -->
                <Border Background="{StaticResource BrushTertiaryBackground}"
                        BorderBrush="{StaticResource BrushBorderSecondary}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{Binding [jwtbuilder.algorithm_secret_title], Source={StaticResource Loc}}"
                                   FontSize="{DynamicResource FontSizeMedium}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushPrimaryText}" />
                        
                        <!-- Algorithm Selection -->
                        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding [jwtbuilder.algorithm], Source={StaticResource Loc}}"
                                       FontSize="{DynamicResource FontSizeDefault}"
                                       Foreground="{StaticResource BrushSecondaryText}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />

                            <ComboBox Grid.Column="1"
                                      SelectedItem="{Binding Algorithm}"
                                      ItemsSource="{Binding AvailableAlgorithms}"
                                      Height="36"
                                      Padding="8"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center" />
                        </Grid>
                        
                        <!-- Secret Key -->
                        <Grid ColumnDefinitions="120,Auto,Auto,Auto,*" RowDefinitions="Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding [jwtbuilder.secret_key], Source={StaticResource Loc}}"
                                       FontSize="{DynamicResource FontSizeDefault}"
                                       Foreground="{StaticResource BrushSecondaryText}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            
                                <controls:EyeToggleButton Grid.Column="1"
                                    Margin="0,0,4,0"
                                    IsToggled="{Binding IsSecretVisible}"
                                    ToolTipText="{Binding [jwtbuilder.toggle_secret], Source={StaticResource Loc}}"
                                    Command="{Binding ToggleSecretVisibilityCommand}" />
                            
                            <Button Grid.Column="2"
                                    Content="{Binding [jwtbuilder.generate_secret], Source={StaticResource Loc}}"
                                    Height="36"
                                    Padding="8,0"
                                    Margin="0,0,4,0"
                                    Classes="NeutralActionButton"
                                    ToolTip.Tip="{Binding [jwtbuilder.generate_secret_tooltip], Source={StaticResource Loc}}"
                                    Command="{Binding GenerateSecretKeyCommand}" />
                            
                                <controls:CopyActionButton Grid.Column="3"
                                                           Width="36"
                                                           Height="36"
                                                           Margin="0,0,4,0"
                                                           ToolTipText="{Binding [jwtbuilder.copy_secret_tooltip], Source={StaticResource Loc}}"
                                                           Command="{Binding CopySecretCommand}" />
                            
                            <TextBox Grid.Column="4"
                                     Text="{Binding Secret}"
                                     PasswordChar="●"
                                     RevealPassword="{Binding IsSecretVisible}"
                                     Padding="8"
                                     Height="36"
                                     TextWrapping="NoWrap"
                                     MaxLines="1"
                                     VerticalAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     Classes="MonospaceInputTextBox"
                                     Watermark="{Binding [jwtbuilder.secret_watermark], Source={StaticResource Loc}}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled" />
                        </Grid>
                        
                        <!-- Public Key (only for RSA algorithms) -->
                        <Grid ColumnDefinitions="120,Auto,*" 
                              RowDefinitions="Auto"
                              IsVisible="{Binding IsRsaAlgorithm}">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding [jwtbuilder.public_key], Source={StaticResource Loc}}"
                                       FontSize="{DynamicResource FontSizeDefault}"
                                       Foreground="{StaticResource BrushSecondaryText}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            
                                <controls:CopyActionButton Grid.Column="1"
                                                           Width="36"
                                                           Height="36"
                                                           Margin="0,0,4,0"
                                                           ToolTipText="{Binding [jwtbuilder.copy_public_key_tooltip], Source={StaticResource Loc}}"
                                                           Command="{Binding CopyPublicKeyCommand}" />
                            
                            <TextBox Grid.Column="2"
                                     Text="{Binding PublicKey}"
                                     IsReadOnly="True"
                                     Padding="8"
                                     Height="36"
                                     TextWrapping="NoWrap"
                                     MaxLines="1"
                                     VerticalAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     Classes="MonospaceInputTextBox"
                                     Watermark="{Binding [jwtbuilder.public_key_watermark], Source={StaticResource Loc}}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled" />
                        </Grid>
                        
                        <TextBlock Text="{Binding [jwtbuilder.hmac_hint], Source={StaticResource Loc}}"
                                   FontSize="{DynamicResource FontSizeSmall}"
                                   Foreground="{StaticResource BrushSecondaryText}"
                                   TextWrapping="Wrap" />
                        
                        <TextBlock Text="{Binding [jwtbuilder.rsa_hint], Source={StaticResource Loc}}"
                                   FontSize="{DynamicResource FontSizeSmall}"
                                   Foreground="{StaticResource BrushSecondaryText}"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding IsRsaAlgorithm}" />
                    </StackPanel>
                </Border>

                <!-- Standard Claims -->
                <Border Background="{StaticResource BrushTertiaryBackground}"
                        BorderBrush="{StaticResource BrushBorderSecondary}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{Binding [jwtbuilder.standard_claims], Source={StaticResource Loc}}"
                                   FontSize="{DynamicResource FontSizeMedium}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushPrimaryText}" />
                        
                        <!-- Issuer -->
                        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding [jwtbuilder.issuer], Source={StaticResource Loc}}"
                                       FontSize="{DynamicResource FontSizeDefault}"
                                       Foreground="{StaticResource BrushSecondaryText}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            
                            <TextBox Grid.Column="1"
                                     Text="{Binding Issuer}"
                                     Padding="8"
                                     Height="36"
                                     VerticalContentAlignment="Center"
                                     Watermark="{Binding [jwtbuilder.issuer_watermark], Source={StaticResource Loc}}" />
                        </Grid>
                        
                        <!-- Audience -->
                        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding [jwtbuilder.audience], Source={StaticResource Loc}}"
                                       FontSize="{DynamicResource FontSizeDefault}"
                                       Foreground="{StaticResource BrushSecondaryText}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            
                            <TextBox Grid.Column="1"
                                     Text="{Binding Audience}"
                                     Padding="8"
                                     Height="36"
                                     VerticalContentAlignment="Center"
                                     Watermark="{Binding [jwtbuilder.audience_watermark], Source={StaticResource Loc}}" />
                        </Grid>
                        
                        <!-- Subject -->
                        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding [jwtbuilder.subject], Source={StaticResource Loc}}"
                                       FontSize="{DynamicResource FontSizeDefault}"
                                       Foreground="{StaticResource BrushSecondaryText}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            
                            <TextBox Grid.Column="1"
                                     Text="{Binding Subject}"
                                     Padding="8"
                                     Height="36"
                                     VerticalContentAlignment="Center"
                                     Watermark="{Binding [jwtbuilder.subject_watermark], Source={StaticResource Loc}}" />
                        </Grid>
                        
                        <!-- Expiration -->
                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto">
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding IncludeExpiration}"
                                      Content="{Binding [jwtbuilder.expiration], Source={StaticResource Loc}}"
                                      MinWidth="120"
                                      FontSize="{DynamicResource FontSizeDefault}"
                                      Foreground="{StaticResource BrushSecondaryText}"
                                      VerticalAlignment="Center" />
                            
                            <NumericUpDown Grid.Column="1"
                                           Value="{Binding ExpirationMinutes}"
                                           Minimum="1"
                                           Maximum="525600"
                                           Increment="5"
                                           MinWidth="80"
                                           Height="36"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Center"
                                           IsEnabled="{Binding IncludeExpiration}"
                                           Margin="8,0,4,0" />
                            
                            <TextBlock Grid.Column="2"
                                       Text="{Binding [jwtbuilder.minutes_later], Source={StaticResource Loc}}"
                                       FontSize="{DynamicResource FontSizeDefault}"
                                       Foreground="{StaticResource BrushSecondaryText}"
                                       VerticalAlignment="Center" />
                        </Grid>
                        
                        <TextBlock Text="{Binding [jwtbuilder.issued_at_hint], Source={StaticResource Loc}}"
                                   FontSize="{DynamicResource FontSizeSmall}"
                                   Foreground="{StaticResource BrushSecondaryText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Custom Claims -->
                <Border Background="{StaticResource BrushTertiaryBackground}"
                        BorderBrush="{StaticResource BrushBorderSecondary}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{Binding [jwtbuilder.custom_claims], Source={StaticResource Loc}}"
                                   FontSize="{DynamicResource FontSizeMedium}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushPrimaryText}" />
                        
                        <!-- Add Custom Claim -->
                        <Grid ColumnDefinitions="*,*,Auto" RowDefinitions="Auto">
                            <TextBox Grid.Column="0"
                                     Text="{Binding CustomClaimKey}"
                                     Padding="8"
                                     Height="36"
                                     VerticalContentAlignment="Center"
                                     Watermark="{Binding [jwtbuilder.claim_key_watermark], Source={StaticResource Loc}}"
                                     Margin="0,0,8,0" />
                            
                            <TextBox Grid.Column="1"
                                     Text="{Binding CustomClaimValue}"
                                     Padding="8"
                                     Height="36"
                                     VerticalContentAlignment="Center"
                                     Watermark="{Binding [jwtbuilder.claim_value_watermark], Source={StaticResource Loc}}"
                                     Margin="0,0,8,0" />
                            
                            <Button Grid.Column="2"
                                    Content="{Binding [jwtbuilder.add_claim], Source={StaticResource Loc}}"
                                    Command="{Binding AddCustomClaimCommand}"
                                    Classes="ActionButton AccentActionButton"
                                    Height="36"
                                    FontWeight="SemiBold" />
                        </Grid>
                        
                        <!-- Custom Claims List -->
                        <ItemsControl ItemsSource="{Binding CustomClaims}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BrushSecondaryBackground}"
                                            BorderBrush="{StaticResource BrushBorder}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="8"
                                            Margin="0,0,0,4">
                                        <Grid ColumnDefinitions="*,*">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Key}"
                                                       FontSize="{DynamicResource FontSizeDefault}"
                                                       FontFamily="{DynamicResource FontMonospace}"
                                                       Foreground="{StaticResource BrushPrimaryText}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0" />
                                            
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Value}"
                                                       FontSize="{DynamicResource FontSizeDefault}"
                                                       FontFamily="{DynamicResource FontMonospace}"
                                                       Foreground="{StaticResource BrushSecondaryText}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,8,0" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <TextBlock Text="{Binding [jwtbuilder.empty_claims], Source={StaticResource Loc}}"
                                   FontSize="{DynamicResource FontSizeDefault}"
                                   Foreground="{StaticResource BrushSecondaryText}"
                                   FontStyle="Italic"
                                   HorizontalAlignment="Center"
                                   IsVisible="{Binding !CustomClaims.Count}" />
                    </StackPanel>
                </Border>

                <!-- Build Actions -->
                <Border Background="{StaticResource BrushTertiaryBackground}"
                        BorderBrush="{StaticResource BrushBorderSecondary}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Center">
                        <Button Content="{Binding [jwtbuilder.build_token], Source={StaticResource Loc}}"
                                Command="{Binding BuildTokenCommand}"
                                Classes="ActionButton AccentActionButton"
                                FontWeight="SemiBold"
                                FontSize="{DynamicResource FontSizeMedium}"
                                Padding="16,8" />
                        
                        <Button Content="{Binding [jwtbuilder.clear], Source={StaticResource Loc}}"
                                Command="{Binding ClearCommand}"
                                Classes="ActionButton DangerActionButton"
                                FontSize="{DynamicResource FontSizeMedium}"
                                Padding="16,8" />
                    </StackPanel>
                </Border>

                <!-- Error Message -->
                <Border Background="{StaticResource BrushDanger}"
                        BorderBrush="{StaticResource BrushDanger}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               FontSize="{DynamicResource FontSizeDefault}"
                               Foreground="White"
                               TextWrapping="Wrap" />
                </Border>

                <!-- Generated Token Output -->
                <Border Background="{StaticResource BrushTertiaryBackground}"
                        BorderBrush="{StaticResource BrushSuccess}"
                        BorderThickness="2"
                        CornerRadius="6"
                        Padding="12"
                        IsVisible="{Binding HasGeneratedToken}">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding [jwtbuilder.generated_token], Source={StaticResource Loc}}"
                                       FontSize="{DynamicResource FontSizeMedium}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushPrimaryText}"
                                       VerticalAlignment="Center" />
                            
                            <controls:CopyActionButton Grid.Column="1"
                                                       Command="{Binding CopyTokenCommand}"
                                                       Width="32"
                                                       Height="32"
                                                       ToolTipText="{Binding [createguid.copy], Source={StaticResource Loc}}" />
                        </Grid>
                        
                        <Border Background="{StaticResource BrushSecondaryBackground}"
                                BorderBrush="{StaticResource BrushBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12">
                            <TextBox Text="{Binding GeneratedToken, Mode=OneWay}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="120"
                                     MaxHeight="300"
                                     FontFamily="{DynamicResource FontMonospace}"
                                     FontSize="{DynamicResource FontSizeSmall}"
                                     Foreground="{StaticResource BrushPrimaryText}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Template Management -->
                <Border Background="{StaticResource BrushTertiaryBackground}"
                        BorderBrush="{StaticResource BrushBorderSecondary}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,12,0,0">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{Binding [jwtbuilder.template_management], Source={StaticResource Loc}}"
                                   FontSize="{DynamicResource FontSizeMedium}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushPrimaryText}" />
                        
                        <!-- Load Template Section -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding [jwtbuilder.load_template], Source={StaticResource Loc}}"
                                       FontSize="{DynamicResource FontSizeDefault}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushSecondaryText}" />
                            
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <ComboBox Grid.Column="0"
                                          SelectedItem="{Binding SelectedTemplate}"
                                          ItemsSource="{Binding SavedTemplates}"
                                          Height="36"
                                          Padding="8"
                                          Margin="0,0,4,0"
                                          PlaceholderText="{Binding [jwtbuilder.template_placeholder], Source={StaticResource Loc}}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding TemplateName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                
                                <controls:LoadActionButton Grid.Column="1"
                                        Margin="0,0,4,0"
                                        ToolTipText="{Binding [jwtbuilder.template_load_tooltip], Source={StaticResource Loc}}"
                                        Command="{Binding LoadTemplateCommand}" />
                                
                                <controls:DeleteActionButton Grid.Column="2"
                                    ToolTipText="{Binding [jwtbuilder.template_delete_tooltip], Source={StaticResource Loc}}"
                                    Command="{Binding DeleteTemplateCommand}" />
                                    </Grid>
                                </StackPanel>
                        
                        <!-- Save Template Section -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding [jwtbuilder.save_template], Source={StaticResource Loc}}"
                                       FontSize="{DynamicResource FontSizeDefault}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushSecondaryText}" />
                            
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBox Grid.Column="0"
                                         Text="{Binding TemplateName}"
                                         Height="36"
                                         Padding="8"
                                         Margin="0,0,4,0"
                                         Watermark="{Binding [jwtbuilder.template_name_watermark], Source={StaticResource Loc}}" />
                                
                                <controls:SaveActionButton Grid.Column="1"
                                        Margin="0,0,4,0"
                                        ToolTipText="{Binding [jwtbuilder.template_save_new_tooltip], Source={StaticResource Loc}}"
                                        Command="{Binding SaveAsNewTemplateCommand}" />
                                
                                <controls:UpdateActionButton Grid.Column="2"
                                        IsEnabled="{Binding CanUpdateTemplate}"
                                        ToolTipText="{Binding [jwtbuilder.template_update_tooltip], Source={StaticResource Loc}}"
                                    Command="{Binding UpdateCurrentTemplateCommand}" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
