<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DevCrew.Desktop.ViewModels"
             x:Class="DevCrew.Desktop.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">
    <ScrollViewer>
        <Border Padding="{DynamicResource ResponsivePaddingMedium}" Background="{StaticResource BrushSecondaryBackground}">
            <StackPanel Spacing="24" HorizontalAlignment="Stretch">
                <TextBlock Text="{Binding [dashboard.title], Source={StaticResource Loc}}"
                           FontSize="{StaticResource FontSizeXLarge}"
                           FontWeight="Bold"
                           Foreground="{StaticResource BrushPrimaryText}"
                           HorizontalAlignment="Center" />

                
                <ItemsControl ItemsSource="{Binding MenuItems}" HorizontalAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Stretch" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding Command}"
                                    Classes="DashboardTile">
                                <StackPanel Spacing="8" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Icon}"
                                               FontSize="32"
                                               HorizontalAlignment="Center"
                                               IsVisible="{Binding Icon, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                    <TextBlock Text="{Binding Header}"
                                               FontSize="{StaticResource FontSizeLarge}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrushPrimaryText}"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
