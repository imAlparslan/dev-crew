<UserControl xmlns="https://github.com/avaloniaui"
                         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                         xmlns:vm="using:DevCrew.Desktop.ViewModels"
                         xmlns:conv="using:DevCrew.Desktop.Converters"
                         x:Class="DevCrew.Desktop.Views.CreateGuidView"
                         x:DataType="vm:CreateGuidViewModel"
                         PointerPressed="OnRootPointerPressed">
        <UserControl.Resources>
                <conv:BooleanToBrushConverter x:Key="GuidBackgroundConverter"
                                                                          TrueBrush="{StaticResource BrushAccent}"
                                                                          FalseBrush="{StaticResource BrushTertiaryBackground}" />
                <conv:BooleanToBrushConverter x:Key="GuidBorderConverter"
                                                                          TrueBrush="{StaticResource BrushAccentDark}"
                                                                          FalseBrush="{StaticResource BrushBorderSecondary}" />
                <conv:BoolToDoubleConverter x:Key="BoolToOpacityConverter" />
        </UserControl.Resources>
    <ScrollViewer>
        <Border Padding="{DynamicResource ResponsivePaddingMedium}" Background="{StaticResource BrushSecondaryBackground}">
            <Grid RowDefinitions="Auto,*" MaxWidth="900" HorizontalAlignment="Center">
                <!-- Top Section - Fixed -->
                <Grid Grid.Row="0"
                      RowDefinitions="Auto,Auto,Auto,Auto"
                      Margin="{DynamicResource ResponsiveMarginSmall}">
                    <TextBlock Grid.Row="0"
                               Text="GUID Oluşturucu"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrushPrimaryText}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20" />
                    
                    <TextBlock Grid.Row="1"
                               Text="Yeni bir GUID üretmek için butona tıklayın"
                               FontSize="14"
                               Foreground="{StaticResource BrushSecondaryText}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,0,0,20" />
                    
                    <Button Grid.Row="2"
                            Content="🎲 Yeni GUID Üret"
                            Command="{Binding GenerateGuidCommand}"
                            HorizontalAlignment="Stretch"
                            Padding="12,10"
                            Background="{StaticResource BrushSuccess}"
                            Foreground="{StaticResource BrushPrimaryText}"
                            BorderBrush="{StaticResource BrushSuccessDark}"
                            CornerRadius="8"
                            FontWeight="SemiBold"
                            Margin="0,0,0,12" />
                    
                    <Border Grid.Row="3"
                        x:Name="GuidBorder"
                        Padding="6,4"
                        Width="580"
                        Height="44"
                        HorizontalAlignment="Left"
                        ClipToBounds="True"
                        Background="{Binding IsGuidCopied, Converter={StaticResource GuidBackgroundConverter}}"
                        BorderBrush="{Binding IsGuidCopied, Converter={StaticResource GuidBorderConverter}}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <Grid ColumnDefinitions="46,488,46" Height="32" VerticalAlignment="Center" HorizontalAlignment="Stretch" ClipToBounds="True">
                        <Button Grid.Column="0"
                            Content="📋"
                            Command="{Binding CopyToClipboardCommand}"
                            IsEnabled="{Binding HasGuid}"
                            Opacity="{Binding HasGuid, Converter={StaticResource BoolToOpacityConverter}}"
                            IsHitTestVisible="{Binding HasGuid}"
                            Width="40"
                            HorizontalAlignment="Left"
                            Padding="6,4"
                            Background="{StaticResource BrushAccent}"
                            Foreground="{StaticResource BrushPrimaryText}"
                            BorderBrush="{StaticResource BrushAccentDark}"
                            CornerRadius="4"
                            Margin="0,0,6,0"
                            ToolTip.Tip="Kopyala" />

                        <TextBox Grid.Column="1"
                             Text="{Binding CurrentGuid}"
                             AcceptsReturn="False"
                             IsReadOnly="True"
                             Padding="6,4"
                             Height="32"
                             Width="488"
                             TextWrapping="NoWrap"
                             MaxLines="1"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Center"
                             VerticalContentAlignment="Center"
                             UseLayoutRounding="False"
                             ClipToBounds="True"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource BrushPrimaryText}"
                             FontFamily="Consolas, Courier New, monospace"
                             Watermark="GUID burada görünecek"
                             SelectionBrush="{StaticResource BrushAccent}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled" />

                        <Button Grid.Column="2"
                            Content="✕"
                            Command="{Binding ClearCommand}"
                            IsEnabled="{Binding HasGuid}"
                            Opacity="{Binding HasGuid, Converter={StaticResource BoolToOpacityConverter}}"
                            IsHitTestVisible="{Binding HasGuid}"
                            Width="40"
                            HorizontalAlignment="Right"
                            Padding="6,4"
                            Background="{StaticResource BrushDanger}"
                            Foreground="{StaticResource BrushPrimaryText}"
                            BorderBrush="{StaticResource BrushDangerDark}"
                            CornerRadius="4"
                            Margin="6,0,0,0"
                            ToolTip.Tip="Temizle" />
                        </Grid>
                    </Border>
                </Grid>
                
                <!-- Recently Generated GUIDs List - Scrollable -->
                <Border Grid.Row="1"
                        BorderBrush="{StaticResource BrushBorderSecondary}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Background="{StaticResource BrushTertiaryBackground}"
                        Margin="{DynamicResource ResponsiveMarginSmall}"
                    IsVisible="{Binding RecentGuids.Count}">
                <Grid RowDefinitions="Auto,*">
                    <!-- Title with Filter Checkbox -->
                    <Grid Grid.Row="0"
                          ColumnDefinitions="*,Auto,Auto"
                          Height="40"
                          Margin="0,0,0,8">
                        <TextBlock Grid.Column="0"
                                   Text="Son Üretilen GUID'ler"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushPrimaryText}"
                                   VerticalAlignment="Center" />
                        
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchQuery}"
                                 Watermark="Açıklamada ara..."
                                 FontSize="12"
                                 Padding="8,6"
                                 MinHeight="32"
                                 Height="32"
                                 MaxHeight="32"
                                 TextWrapping="NoWrap"
                                 MaxLines="1"
                                 VerticalAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 UseLayoutRounding="False"
                                 ClipToBounds="True"
                                 Margin="0,0,8,0"
                                 Background="{StaticResource BrushTertiaryBackground}"
                                 Foreground="{StaticResource BrushSecondaryText}"
                                 BorderBrush="{StaticResource BrushBorderSecondary}"
                                 CornerRadius="4"
                                 Width="200"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled" />
                        
                        <CheckBox Grid.Column="2"
                                  Content="Kayıtlılar"
                                  IsChecked="{Binding ShowOnlySavedGuids}"
                                  Foreground="{StaticResource BrushSecondaryText}"
                                  VerticalAlignment="Center" />
                    </Grid>
                    
                    <!-- Scrollable Content -->
                    <ScrollViewer Grid.Row="1"
                                  x:Name="GuidsScrollViewer"
                                  IsVisible="{Binding FilteredGuidsByPage.Count}">
                        <ItemsControl ItemsSource="{Binding FilteredGuidsByPage}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BrushSecondaryBackground}"
                                        BorderBrush="{StaticResource BrushBorderSecondary}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="8,6"
                                        Margin="0,2">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <!-- Column 1: GUID Value -->
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding GuidValue}"
                                                   FontFamily="Consolas, Courier New, monospace"
                                                   FontSize="12"
                                                   Foreground="{StaticResource BrushSecondaryText}"
                                                   VerticalAlignment="Center"
                                                   MinWidth="250"
                                                   MaxWidth="350"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,8,0" />
                                        
                                        <!-- Column 2: Notes TextBox -->
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding Notes}"
                                                 Watermark="Not ekle (opsiyonel)"
                                                 FontSize="11"
                                                 Padding="6,4"
                                                 MinHeight="28"
                                                 Height="28"
                                                 MaxHeight="28"
                                                 TextWrapping="NoWrap"
                                                 MaxLines="1"
                                                 HorizontalAlignment="Stretch"
                                                 VerticalAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 UseLayoutRounding="False"
                                                 ClipToBounds="True"
                                                 Background="{StaticResource BrushTertiaryBackground}"
                                                 Foreground="{StaticResource BrushSecondaryText}"
                                                 BorderBrush="{StaticResource BrushBorderSecondary}"
                                                 CornerRadius="3"
                                                 Margin="0,0,8,0"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ScrollViewer.VerticalScrollBarVisibility="Disabled" />
                                        
                                        <!-- Column 3: Action Buttons -->
                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    Spacing="4"
                                                    VerticalAlignment="Center">
                                            <Button Command="{Binding $parent[UserControl].DataContext.SaveGuidCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsEnabled="{Binding !IsSaved}"
                                                    Padding="6,4"
                                                    Background="{StaticResource BrushSuccess}"
                                                    Foreground="{StaticResource BrushPrimaryText}"
                                                    BorderBrush="{StaticResource BrushSuccessDark}"
                                                    CornerRadius="4"
                                                    ToolTip.Tip="Kaydet">
                                                <TextBlock Text="💾" />
                                            </Button>
                                            
                                            <Button Command="{Binding $parent[UserControl].DataContext.CopyGuidItemCommand}"
                                                    CommandParameter="{Binding}"
                                                    Padding="6,4"
                                                    Background="{StaticResource BrushAccent}"
                                                    Foreground="{StaticResource BrushPrimaryText}"
                                                    BorderBrush="{StaticResource BrushAccentDark}"
                                                    CornerRadius="4"
                                                    ToolTip.Tip="Kopyala">
                                                <TextBlock Text="📋" />
                                            </Button>
                                            
                                            <Button Command="{Binding $parent[UserControl].DataContext.DeleteGuidCommand}"
                                                    CommandParameter="{Binding}"
                                                    Padding="6,4"
                                                    Background="{StaticResource BrushDanger}"
                                                    Foreground="{StaticResource BrushPrimaryText}"
                                                    BorderBrush="{StaticResource BrushDangerDark}"
                                                    CornerRadius="4"
                                                    ToolTip.Tip="Sil">
                                                <TextBlock Text="🗑️" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Border>
    </ScrollViewer>
</UserControl>
