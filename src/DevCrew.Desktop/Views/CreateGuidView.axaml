<UserControl xmlns="https://github.com/avaloniaui"
                         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                         xmlns:vm="using:DevCrew.Desktop.ViewModels"
                         xmlns:conv="using:DevCrew.Desktop.Converters"
                         x:Class="DevCrew.Desktop.Views.CreateGuidView"
                         x:DataType="vm:CreateGuidViewModel">
        <UserControl.Resources>
                <conv:BooleanToBrushConverter x:Key="GuidBackgroundConverter"
                                                                          TrueBrush="{StaticResource BrushAccent}"
                                                                          FalseBrush="{StaticResource BrushTertiaryBackground}" />
                <conv:BooleanToBrushConverter x:Key="GuidBorderConverter"
                                                                          TrueBrush="{StaticResource BrushAccentDark}"
                                                                          FalseBrush="{StaticResource BrushBorderSecondary}" />
        </UserControl.Resources>
    <Border Padding="16" Background="{StaticResource BrushSecondaryBackground}">
        <StackPanel Spacing="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="360">
            <TextBlock Text="GUID Oluşturucu"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{StaticResource BrushPrimaryText}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8" />
            
            <TextBlock Text="Yeni bir GUID üretmek için butona tıklayın"
                       FontSize="14"
                       Foreground="{StaticResource BrushSecondaryText}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,0,0,8" />
            
            <Button Content="🎲 Yeni GUID Üret"
                    Command="{Binding GenerateGuidCommand}"
                    HorizontalAlignment="Stretch"
                    Padding="12,10"
                    Background="{StaticResource BrushSuccess}"
                    Foreground="{StaticResource BrushPrimaryText}"
                    BorderBrush="{StaticResource BrushSuccessDark}"
                    CornerRadius="8"
                    FontWeight="SemiBold" />
            
            <TextBox Text="{Binding CurrentGuid}"
                     AcceptsReturn="False"
                     IsReadOnly="True"
                     Margin="0,4,0,0"
                     Padding="10"
                     Background="{Binding IsGuidCopied, Converter={StaticResource GuidBackgroundConverter}}"
                     BorderBrush="{Binding IsGuidCopied, Converter={StaticResource GuidBorderConverter}}"
                     Foreground="{StaticResource BrushPrimaryText}"
                     FontFamily="Consolas, Courier New, monospace"
                     Watermark="GUID burada görünecek"
                     SelectionBrush="{StaticResource BrushAccent}" />
            
            <StackPanel Orientation="Horizontal" 
                        Spacing="8" 
                        HorizontalAlignment="Center"
                        Margin="0,8,0,0">
                <Button Content="📋 Kopyala"
                        Command="{Binding CopyToClipboardCommand}"
                        IsEnabled="{Binding HasGuid}"
                        Padding="12,8"
                        Background="{StaticResource BrushAccent}"
                        Foreground="{StaticResource BrushPrimaryText}"
                        BorderBrush="{StaticResource BrushAccentDark}"
                        CornerRadius="6" />
                
                <Button Content="🗑️ Temizle"
                        Command="{Binding ClearCommand}"
                        IsEnabled="{Binding HasGuid}"
                        Padding="12,8"
                        Background="{StaticResource BrushDanger}"
                        Foreground="{StaticResource BrushPrimaryText}"
                        BorderBrush="{StaticResource BrushDangerDark}"
                        CornerRadius="6" />
            </StackPanel>
            
        </StackPanel>
    </Border>
</UserControl>
