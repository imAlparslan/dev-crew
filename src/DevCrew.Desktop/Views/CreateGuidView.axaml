<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DevCrew.Desktop.ViewModels"
             x:Class="DevCrew.Desktop.Views.CreateGuidView"
             x:DataType="vm:CreateGuidViewModel">
    <Border Padding="16" Background="#1E293B">
        <StackPanel Spacing="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="360">
            <TextBlock Text="GUID Oluşturucu"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#F8FAFC"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8" />
            
            <TextBlock Text="Yeni bir GUID üretmek için butona tıklayın"
                       FontSize="14"
                       Foreground="#CBD5E1"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,0,0,8" />
            
            <Button Content="🎲 Yeni GUID Üret"
                    Command="{Binding GenerateGuidCommand}"
                    HorizontalAlignment="Stretch"
                    Padding="12,10"
                    Background="#16A34A"
                    Foreground="White"
                    BorderBrush="#15803D"
                    CornerRadius="8"
                    FontWeight="SemiBold" />
            
            <TextBox Text="{Binding CurrentGuid}"
                     AcceptsReturn="False"
                     IsReadOnly="True"
                     Margin="0,4,0,0"
                     Padding="10"
                     Background="#334155"
                     BorderBrush="#475569"
                     Foreground="#F8FAFC"
                     FontFamily="Consolas, Courier New, monospace"
                     Watermark="GUID burada görünecek"
                     SelectionBrush="#0EA5E9" />
            
            <StackPanel Orientation="Horizontal" 
                        Spacing="8" 
                        HorizontalAlignment="Center"
                        Margin="0,8,0,0">
                <Button Content="📋 Kopyala"
                        Command="{Binding CopyToClipboardCommand}"
                        IsEnabled="{Binding HasGuid}"
                        Padding="12,8"
                        Background="#0EA5E9"
                        Foreground="White"
                        BorderBrush="#0284C7"
                        CornerRadius="6" />
                
                <Button Content="🗑️ Temizle"
                        Command="{Binding ClearCommand}"
                        IsEnabled="{Binding HasGuid}"
                        Padding="12,8"
                        Background="#EF4444"
                        Foreground="White"
                        BorderBrush="#DC2626"
                        CornerRadius="6" />
            </StackPanel>
            
        </StackPanel>
    </Border>
</UserControl>
