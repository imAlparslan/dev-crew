<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DevCrew.Desktop.Views.MainWindow"
        Icon="avares://DevCrew.Desktop/Assets/icons/windows/app.ico"
    Title="{Binding Title}"
        MinWidth="480"
        MinHeight="400"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate x:Key="TabHeaderTemplate">
            <StackPanel Orientation="Horizontal" Spacing="4" ToolTip.Tip="{Binding Tooltip}">
                <TextBlock Text="{Binding Icon}" 
                           VerticalAlignment="Center"
                           IsVisible="{Binding Icon, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                <TextBlock Text="{Binding Header}" VerticalAlignment="Center" />
                <Button Content="×"
                        Command="{Binding $parent[Window].DataContext.CloseTabCommand}"
                        CommandParameter="{Binding}"
                        IsVisible="{Binding IsClosable}"
                        Width="20"
                        Height="20"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="{DynamicResource FontSizeLarge}"
                        VerticalAlignment="Center"
                        ToolTip.Tip="{Binding $parent[Window].DataContext.CloseTabTooltip}" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="ToggleButton.menu-item">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}" />
            <Setter Property="BorderBrush" Value="{StaticResource BrushButtonSecondary}" />
            <Setter Property="Background" Value="{StaticResource BrushButtonPrimary}" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style Selector="ToggleButton.menu-item:checked">
            <Setter Property="Background" Value="{StaticResource BrushSecondaryBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto, *">
        <!-- Üst bar: sol menüyü aç/kapat, başlık -->
        <Border Grid.Row="0"
                Background="{StaticResource BrushPrimaryBackground}"
                Padding="8,4"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,Auto,*"
                  VerticalAlignment="Center">
                <Button Grid.Column="0"
                        Width="36"
                        Height="36"
                        CornerRadius="8"
                        Background="{StaticResource BrushButtonSecondary}"
                        Foreground="White"
                        Content="☰"
                        Command="{Binding ToggleSidebarCommand}" />

                <StackPanel Grid.Column="1"
                        Orientation="Vertical"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"
                           FontSize="{DynamicResource FontSizeHeading}"
                              FontFamily="{DynamicResource FontHeading}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrushPrimaryText}" />
                </StackPanel>

                <TabStrip Grid.Column="2"
                          ItemsSource="{Binding Tabs}"
                          SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                          ItemTemplate="{StaticResource TabHeaderTemplate}"
                          Classes="top-tabs"
                          Margin="100,0,0,0"
                          VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Ana alan: sol panel + içerik -->
        <SplitView Grid.Row="1"
                   IsPaneOpen="{Binding IsSidebarOpen, Mode=TwoWay}"
                   OpenPaneLength="240"
                   CompactPaneLength="0"
                   DisplayMode="Inline"
                   PanePlacement="Left">
            <SplitView.Pane>
                <Border Background="{StaticResource BrushSurfaceBackground}"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="0,0,1,0"
                        Padding="16">
                    <Grid RowDefinitions="Auto,*,Auto,Auto">
                        <TextBlock Grid.Row="0"
                                   Text="{Binding MenuTitle}"
                                   FontSize="{DynamicResource FontSizeLarge}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushPrimaryText}"
                                   Margin="0,0,0,8" />

                        <ScrollViewer Grid.Row="1"
                                      Margin="0,0,0,12"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding MenuItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ToggleButton Classes="menu-item"
                                                      Command="{Binding Command}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding Icon}"
                                                           IsVisible="{Binding Icon, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                <TextBlock Text="{Binding Header}" />
                                            </StackPanel>
                                        </ToggleButton>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Border Grid.Row="2"
                                Height="1"
                                Background="{StaticResource BrushBorder}"
                                Opacity="0.8" />

                        <StackPanel Grid.Row="3"
                                    Margin="0,12,0,0"
                                    Spacing="8">
                            <ItemsControl ItemsSource="{Binding BottomMenuItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ToggleButton Classes="menu-item"
                                                      Command="{Binding Command}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding Icon}"
                                                           IsVisible="{Binding Icon, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                <TextBlock Text="{Binding Header}" />
                                            </StackPanel>
                                        </ToggleButton>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </Border>
            </SplitView.Pane>

            <SplitView.Content>
                <ContentControl Content="{Binding SelectedTab.Content}" />
            </SplitView.Content>
        </SplitView>
    </Grid>
</Window>
