<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:b="using:DevCrew.Desktop.Behaviors"
             xmlns:converters="using:DevCrew.Desktop.Converters"
             xmlns:vm="using:DevCrew.Desktop.ViewModels"
             x:Class="DevCrew.Desktop.Views.RegexView"
             x:DataType="vm:RegexViewModel">

    <UserControl.Resources>
        <converters:BooleanToBrushConverter x:Key="RegexValidationBackgroundBrushConverter"
                                            TrueBrush="{StaticResource BrushRegexValidationSuccessBackground}"
                                            FalseBrush="{StaticResource BrushRegexValidationErrorBackground}" />
        <converters:BooleanToBrushConverter x:Key="RegexValidationBrushConverter"
                                            TrueBrush="{StaticResource BrushRegexValidationSuccess}"
                                            FalseBrush="{StaticResource BrushRegexValidationError}" />
    </UserControl.Resources>

    <Border Padding="{DynamicResource ResponsivePaddingMedium}" Background="{StaticResource BrushSecondaryBackground}">
        <Grid RowDefinitions="Auto,Auto,Auto,*" HorizontalAlignment="Stretch">
                <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
                    <TextBlock Text="{Binding [regex.title], Source={StaticResource Loc}}"
                               FontSize="{DynamicResource FontSizeHeading}"
                               FontFamily="{DynamicResource FontHeading}"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrushPrimaryText}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <Border Grid.Row="1"
                        Background="{StaticResource BrushTertiaryBackground}"
                        BorderBrush="{StaticResource BrushBorderSecondary}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,0,0,12">
                    <StackPanel Spacing="12">
                        <Border Background="{StaticResource BrushSecondaryBackground}"
                                BorderBrush="{StaticResource BrushBorderSecondary}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12">
                            <StackPanel Spacing="10">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding [regex.preset_management], Source={StaticResource Loc}}"
                                               FontSize="{DynamicResource FontSizeMedium}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrushPrimaryText}" />
                                </StackPanel>

                                <Grid ColumnDefinitions="*,16,*">
                                    <StackPanel Grid.Column="0" Spacing="6">
                                        <TextBlock Text="{Binding [regex.saved_presets], Source={StaticResource Loc}}"
                                                   Foreground="{StaticResource BrushSecondaryText}"
                                                   FontWeight="Medium" />
                                        <Grid ColumnDefinitions="*,12,Auto,12,Auto">
                                            <ComboBox Grid.Column="0"
                                                      ItemsSource="{Binding SavedPresets}"
                                                      SelectedItem="{Binding SelectedPreset}"
                                                      IsEnabled="{Binding HasSavedPresets}"
                                                      MinHeight="36"
                                                      HorizontalAlignment="Stretch">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:RegexPresetItemViewModel">
                                                        <TextBlock Text="{Binding DisplayPattern}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <Button Grid.Column="2"
                                                    Content="{Binding [regex.preset_edit], Source={StaticResource Loc}}"
                                                    Command="{Binding UpdatePresetCommand}"
                                                    IsEnabled="{Binding SelectedPreset, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                    MinHeight="36"
                                                    Classes="ActionButton SecondaryActionButton"
                                                    ToolTip.Tip="{Binding [regex.preset_edit_tooltip], Source={StaticResource Loc}}" />
                                            <Button Grid.Column="4"
                                                    Content="{Binding [regex.preset_delete], Source={StaticResource Loc}}"
                                                    Command="{Binding DeletePresetCommand}"
                                                    IsEnabled="{Binding SelectedPreset, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                    MinHeight="36"
                                                    Classes="ActionButton DangerActionButton"
                                                    ToolTip.Tip="{Binding [regex.preset_delete_tooltip], Source={StaticResource Loc}}" />
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Spacing="6">
                                        <TextBlock Text="{Binding [regex.save_preset], Source={StaticResource Loc}}"
                                                   Foreground="{StaticResource BrushSecondaryText}"
                                                   FontWeight="Medium" />
                                        <Grid ColumnDefinitions="*,12,Auto">
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding PresetName}"
                                                     MinHeight="36"
                                                     VerticalContentAlignment="Center"
                                                     Watermark="{Binding [regex.preset_name_watermark], Source={StaticResource Loc}}"
                                                     Classes="CompactInputTextBox" />
                                            <Button Grid.Column="2"
                                                    Content="{Binding [regex.save_preset], Source={StaticResource Loc}}"
                                                    Command="{Binding SavePresetCommand}"
                                                    MinHeight="36"
                                                    Classes="ActionButton PrimaryActionButton"
                                                    ToolTip.Tip="{Binding [regex.save_preset_tooltip], Source={StaticResource Loc}}" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Grid ColumnDefinitions="Auto,8,*,12,Auto,12,Auto,12,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding [regex.pattern_title], Source={StaticResource Loc}}"
                                       Foreground="{StaticResource BrushSecondaryText}"
                                       VerticalAlignment="Center" />
                            <TextBox Grid.Column="2"
                                     Text="{Binding Pattern}"
                                     Watermark="{Binding [regex.pattern_watermark], Source={StaticResource Loc}}"
                                     Classes="CompactInputTextBox" />
                            <CheckBox Grid.Column="4"
                                      Content="{Binding [regex.ignore_case], Source={StaticResource Loc}}"
                                      IsChecked="{Binding IgnoreCase}"
                                      VerticalAlignment="Center" />
                            <CheckBox Grid.Column="6"
                                      Content="{Binding [regex.multiline], Source={StaticResource Loc}}"
                                      IsChecked="{Binding Multiline}"
                                      VerticalAlignment="Center" />
                            <Button Grid.Column="8"
                                    Content="{Binding [regex.clear], Source={StaticResource Loc}}"
                                    Command="{Binding ClearCommand}"
                                    Classes="ActionButton DangerActionButton"
                                    ToolTip.Tip="{Binding [regex.clear_tooltip], Source={StaticResource Loc}}" />
                        </Grid>

                        <Grid ColumnDefinitions="*,8,Auto,8,Auto">
                            <TextBox Grid.Column="0"
                                     Text="{Binding SourcePath}"
                                     Watermark="{Binding [regex.path_watermark], Source={StaticResource Loc}}"
                                     Classes="CompactInputTextBox" />
                            <Button Grid.Column="2"
                                    Content="{Binding [regex.load_from_path], Source={StaticResource Loc}}"
                                    Command="{Binding LoadFromPathCommand}"
                                    Classes="ActionButton PrimaryActionButton"
                                    ToolTip.Tip="{Binding [regex.load_from_path_tooltip], Source={StaticResource Loc}}" />
                            <Button Grid.Column="4"
                                    Content="{Binding [regex.browse], Source={StaticResource Loc}}"
                                    Command="{Binding BrowseFileCommand}"
                                    Classes="ActionButton PrimaryActionButton"
                                    ToolTip.Tip="{Binding [regex.browse_tooltip], Source={StaticResource Loc}}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Padding="8"
                        CornerRadius="4"
                        Margin="0,0,0,12"
                        IsVisible="{Binding ValidationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <Border.Background>
                        <Binding Path="IsValid" Converter="{StaticResource RegexValidationBackgroundBrushConverter}" />
                    </Border.Background>
                    <Border.BorderBrush>
                        <Binding Path="IsValid" Converter="{StaticResource RegexValidationBrushConverter}" />
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>

                    <TextBlock Text="{Binding ValidationMessage}"
                               FontSize="{DynamicResource FontSizeDefault}"
                               FontWeight="Medium"
                               TextWrapping="Wrap">
                        <TextBlock.Foreground>
                            <Binding Path="IsValid" Converter="{StaticResource RegexValidationBrushConverter}" />
                        </TextBlock.Foreground>
                    </TextBlock>
                </Border>

                <Border Grid.Row="3"
                        Background="{StaticResource BrushTertiaryBackground}"
                        BorderBrush="{StaticResource BrushBorderSecondary}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        DragDrop.AllowDrop="True"
                        x:Name="InputBorder">
                    <Grid RowDefinitions="Auto,*">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding [regex.text_title], Source={StaticResource Loc}}"
                                       FontSize="{DynamicResource FontSizeLabel}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushSecondaryText}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding MatchCountSummary}"
                                       Foreground="{StaticResource BrushSecondaryText}"
                                       VerticalAlignment="Center" />
                        </Grid>

                        <Grid Grid.Row="1">
                            <ae:TextEditor Name="InputEditor"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                           Background="Transparent"
                                           Foreground="{StaticResource BrushPrimaryText}"
                                           ShowLineNumbers="False"
                                           WordWrap="True"
                                           FontFamily="{DynamicResource FontMonospace}"
                                           FontSize="{DynamicResource FontSizeSmall}"
                                           b:HoverHighlightBehavior.IsEnabled="True" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
    </Border>
</UserControl>