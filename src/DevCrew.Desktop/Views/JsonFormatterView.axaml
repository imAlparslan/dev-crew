<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DevCrew.Desktop.ViewModels"
             xmlns:controls="using:DevCrew.Desktop.Controls"
             x:Class="DevCrew.Desktop.Views.JsonFormatterView"
             x:DataType="vm:JsonFormatterViewModel">
    
    <ScrollViewer>
        <Border Padding="{DynamicResource ResponsivePaddingMedium}" Background="{StaticResource BrushSecondaryBackground}">
            <Grid RowDefinitions="Auto,Auto,*" HorizontalAlignment="Stretch">
                <!-- Header -->
                <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
                    <TextBlock Text="{Binding [jsonformatter.title], Source={StaticResource Loc}}"
                               FontSize="{DynamicResource FontSizeHeading}"
                               FontFamily="{DynamicResource FontHeading}"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrushPrimaryText}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,16">
                    <Button Content="{Binding [jsonformatter.prettify], Source={StaticResource Loc}}"
                            Command="{Binding PrettifyCommand}"
                            Classes="ActionButton PrimaryActionButton"
                            FontWeight="SemiBold"
                            ToolTip.Tip="{Binding [jsonformatter.prettify_tooltip], Source={StaticResource Loc}}" />
                    
                    <Button Content="{Binding [jsonformatter.minify], Source={StaticResource Loc}}"
                            Command="{Binding MinifyCommand}"
                            Classes="ActionButton PrimaryActionButton"
                            FontWeight="SemiBold"
                            ToolTip.Tip="{Binding [jsonformatter.minify_tooltip], Source={StaticResource Loc}}" />
                    
                    <CheckBox Content="{Binding [jsonformatter.sort_keys], Source={StaticResource Loc}}"
                              IsChecked="{Binding IsSortKeysEnabled}"
                              FontWeight="SemiBold"
                              Foreground="{StaticResource BrushPrimaryText}"
                              VerticalAlignment="Center"
                              Margin="8,0"
                              ToolTip.Tip="{Binding [jsonformatter.sort_keys_tooltip], Source={StaticResource Loc}}" />
                    
                    <Button Content="{Binding [jsonformatter.clear], Source={StaticResource Loc}}"
                            Command="{Binding ClearCommand}"
                            Classes="ActionButton DangerActionButton"
                            FontWeight="SemiBold"
                            ToolTip.Tip="{Binding [jsonformatter.clear_tooltip], Source={StaticResource Loc}}" />
                </StackPanel>

                <!-- Input/Output Section -->
                <Grid Grid.Row="2" ColumnDefinitions="*,16,*">
                    <!-- Input Section (Left) -->
                    <Border Grid.Column="0"
                            Background="{StaticResource BrushTertiaryBackground}"
                            BorderBrush="{StaticResource BrushBorderSecondary}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            DragDrop.AllowDrop="True"
                            x:Name="InputBorder">
                        <Grid RowDefinitions="Auto,*">
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [jsonformatter.input_title], Source={StaticResource Loc}}"
                                           FontSize="{DynamicResource FontSizeLabel}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushSecondaryText}"
                                           VerticalAlignment="Center" />
                                
                                <Button Grid.Column="1"
                                    Content="{Binding [jsonformatter.browse], Source={StaticResource Loc}}"
                                        Command="{Binding BrowseFileCommand}"
                                        Padding="10,6"
                                        FontWeight="SemiBold"
                                        Classes="ActionButton PrimaryActionButton"
                                        ToolTip.Tip="{Binding [jsonformatter.browse_tooltip], Source={StaticResource Loc}}" />
                            </Grid>
                            
                            <TextBox x:Name="InputTextBox"
                                     Grid.Row="1"
                                     Text="{Binding InputJson}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="400"
                                     Padding="8"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     VerticalContentAlignment="Top"
                                     Classes="MonospaceInputTextBox"
                                     FontFamily="{DynamicResource FontMonospace}"
                                     FontSize="{DynamicResource FontSizeSmall}"
                                     Watermark="{Binding [jsonformatter.input_watermark], Source={StaticResource Loc}}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </Border>

                    <!-- Output Section (Right) -->
                    <Border Grid.Column="2"
                            Background="{StaticResource BrushTertiaryBackground}"
                            BorderBrush="{StaticResource BrushBorderSecondary}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12">
                        <Grid RowDefinitions="Auto,Auto,*">
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,8">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [jsonformatter.output_title], Source={StaticResource Loc}}"
                                           FontSize="{DynamicResource FontSizeLabel}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushSecondaryText}"
                                           VerticalAlignment="Center" />
                                
                                <controls:CopyActionButton Grid.Column="1"
                                                           Command="{Binding CopyOutputCommand}"
                                                           IsEnabled="{Binding HasOutput}"
                                                           Width="32"
                                                           Height="32"
                                                           Margin="0,0,8,0"
                                                           ToolTipText="{Binding [jsonformatter.copy_output_tooltip], Source={StaticResource Loc}}"
                                                           Cursor="Hand" />

                                <Button Grid.Column="2"
                                        Command="{Binding SaveOutputCommand}"
                                        IsEnabled="{Binding HasOutput}"
                                        Width="32"
                                        Height="32"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ToolTip.Tip="{Binding [jsonformatter.save_output_tooltip], Source={StaticResource Loc}}"
                                        Cursor="Hand">
                                    <PathIcon Data="M17 3H5C3.89 3 3 3.9 3 5V19C3 20.1 3.89 21 5 21H19C20.1 21 21 20.1 21 19V7L17 3M19 19H5V5H16.17L19 7.83V19M12 12C10.34 12 9 13.34 9 15S10.34 18 12 18 15 16.66 15 15 13.66 12 12 12M6 6H15V10H6V6Z"
                                               Width="16" Height="16" />
                                </Button>
                            </Grid>
                            
                            <!-- Validation Message -->
                            <Border Grid.Row="1"
                                    Padding="8"
                                    CornerRadius="4"
                                    Margin="0,0,0,8"
                                    IsVisible="{Binding ValidationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding IsValid, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#2D5F2E|#5F2D2D'}" Opacity="0.2" />
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="{Binding IsValid, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#4CAF50|#F44336'}" />
                                </Border.BorderBrush>
                                <Border.BorderThickness>1</Border.BorderThickness>
                                
                                <TextBlock Text="{Binding ValidationMessage}"
                                           FontSize="{DynamicResource FontSizeDefault}"
                                           FontWeight="Medium"
                                           TextWrapping="Wrap">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="{Binding IsValid, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#4CAF50|#F44336'}" />
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </Border>
                            
                            <TextBox Grid.Row="2"
                                     Text="{Binding OutputJson}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     IsReadOnly="True"
                                     MinHeight="400"
                                     Padding="8"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     VerticalContentAlignment="Top"
                                     Classes="MonospaceInputTextBox"
                                     FontFamily="{DynamicResource FontMonospace}"
                                     FontSize="{DynamicResource FontSizeSmall}"
                                     Watermark="{Binding [jsonformatter.output_watermark], Source={StaticResource Loc}}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </ScrollViewer>
</UserControl>
