<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DevCrew.Desktop.Views.MainWindow"
        Title="DevCrew"
        Width="900"
        Height="640"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate x:Key="TabHeaderTemplate">
            <StackPanel Orientation="Horizontal" Spacing="4" ToolTip.Tip="{Binding Tooltip}">
                <TextBlock Text="{Binding Icon}" 
                           VerticalAlignment="Center"
                           IsVisible="{Binding Icon, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                <TextBlock Text="{Binding Header}" VerticalAlignment="Center" />
                <Button Content="×"
                        Command="{Binding $parent[Window].DataContext.CloseTabCommand}"
                        CommandParameter="{Binding}"
                        IsVisible="{Binding IsClosable}"
                        Width="20"
                        Height="20"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="16"
                        VerticalAlignment="Center"
                        ToolTip.Tip="Kapat" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid RowDefinitions="Auto, *">
        <!-- Üst bar: sol menüyü aç/kapat, başlık -->
        <Border Grid.Row="0"
                Background="{StaticResource BrushPrimaryBackground}"
                Padding="8,4"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,Auto,*"
                  VerticalAlignment="Center">
                <Button Grid.Column="0"
                        Width="36"
                        Height="36"
                        CornerRadius="8"
                        Background="{StaticResource BrushButtonSecondary}"
                        Foreground="White"
                        Content="☰"
                        Command="{Binding ToggleSidebarCommand}" />

                <StackPanel Grid.Column="1"
                        Orientation="Vertical"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrushPrimaryText}" />
                </StackPanel>

                <TabStrip Grid.Column="2"
                          ItemsSource="{Binding Tabs}"
                          SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                          ItemTemplate="{StaticResource TabHeaderTemplate}"
                          Classes="top-tabs"
                          Margin="100,0,0,0"
                          VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Ana alan: sol panel + içerik -->
        <SplitView Grid.Row="1"
                   IsPaneOpen="{Binding IsSidebarOpen, Mode=TwoWay}"
                   OpenPaneLength="240"
                   CompactPaneLength="0"
                   DisplayMode="Inline"
                   PanePlacement="Left">
            <SplitView.Pane>
                <Border Background="{StaticResource BrushSurfaceBackground}"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="0,0,1,0"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Menü"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushPrimaryText}"
                                   Margin="0,0,0,8" />

                        <Button Content="Dashboard"
                                HorizontalAlignment="Stretch"
                                Background="{StaticResource BrushButtonPrimary}"
                                Foreground="{StaticResource BrushPrimaryText}"
                                BorderBrush="{StaticResource BrushButtonSecondary}"
                                Padding="10,8"
                                CornerRadius="6"
                                Command="{Binding OpenDashboardCommand}" />

                        <Button Content="Create Guid"
                                HorizontalAlignment="Stretch"
                                Background="{StaticResource BrushAccent}"
                                Foreground="{StaticResource BrushPrimaryText}"
                                BorderBrush="{StaticResource BrushAccentDark}"
                                Padding="10,8"
                                CornerRadius="6"
                                Command="{Binding OpenCreateGuidTabCommand}" />
                    </StackPanel>
                </Border>
            </SplitView.Pane>

            <SplitView.Content>
                <ContentControl Content="{Binding SelectedTab.Content}" />
            </SplitView.Content>
        </SplitView>
    </Grid>
</Window>
