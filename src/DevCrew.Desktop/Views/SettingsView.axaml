<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DevCrew.Desktop.ViewModels"
             xmlns:conv="using:DevCrew.Desktop.Converters"
             x:Class="DevCrew.Desktop.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
    <UserControl.Resources>
        <conv:FontSizeScaleConverter x:Key="FontSizeScaleConverter" />
    </UserControl.Resources>
    <ScrollViewer>
        <Border Padding="{DynamicResource ResponsivePaddingMedium}" Background="{StaticResource BrushSecondaryBackground}">
            <StackPanel Spacing="24" HorizontalAlignment="Stretch">
                <TextBlock Text="{Binding Title}"
                           FontSize="{DynamicResource FontSizeHeading}"
                           FontFamily="{DynamicResource FontHeading}"
                           FontWeight="Bold"
                           Foreground="{StaticResource BrushPrimaryText}" />

                <!-- Application Language Setting Card -->
                <Border BorderBrush="{StaticResource BrushBorderSecondary}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Background="{StaticResource BrushTertiaryBackground}"
                        HorizontalAlignment="Stretch">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding LanguageLabel}"
                                   FontSize="{DynamicResource FontSizeLabel}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushPrimaryText}" />
                        <ComboBox ItemsSource="{Binding SupportedLanguages}"
                                  SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                                  Height="36">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Update Card -->
                <Border BorderBrush="{StaticResource BrushBorderSecondary}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Background="{StaticResource BrushTertiaryBackground}"
                        HorizontalAlignment="Stretch">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{Binding UpdateSectionTitle}"
                                   FontSize="{DynamicResource FontSizeLabel}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushPrimaryText}" />

                        <Grid ColumnDefinitions="Auto,12,*" RowDefinitions="Auto,8,Auto">
                            <TextBlock Grid.Column="0"
                                       Grid.Row="0"
                                       Text="{Binding CurrentVersionLabel}"
                                       Foreground="{StaticResource BrushSecondaryText}" />
                            <TextBlock Grid.Column="2"
                                       Grid.Row="0"
                                       Text="{Binding CurrentVersion}"
                                       Foreground="{StaticResource BrushPrimaryText}"
                                       FontWeight="SemiBold" />

                            <TextBlock Grid.Column="0"
                                       Grid.Row="2"
                                       Text="{Binding LatestVersionLabel}"
                                       Foreground="{StaticResource BrushSecondaryText}" />
                            <TextBlock Grid.Column="2"
                                       Grid.Row="2"
                                       Text="{Binding LatestVersionDisplay}"
                                       Foreground="{StaticResource BrushPrimaryText}"
                                       FontWeight="SemiBold" />
                        </Grid>

                        <TextBlock Text="{Binding UpdateStatusMessage}"
                                   Foreground="{StaticResource BrushSecondaryText}"
                                   TextWrapping="Wrap" />

                        <ProgressBar IsVisible="{Binding IsUpdateOperationInProgress}"
                                     IsIndeterminate="True"
                                     Height="4"
                                     Margin="0,2,0,0" />

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="{Binding CheckForUpdatesLabel}"
                                    Command="{Binding CheckForUpdatesCommand}"
                                    Classes="ActionButton AccentActionButton" />
                            <Button Content="{Binding UpdateNowLabel}"
                                    Command="{Binding StartUpdateCommand}"
                                    IsVisible="{Binding IsUpdateAvailable}"
                                    Classes="ActionButton PrimaryActionButton" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Font Settings Card -->
                <Border BorderBrush="{StaticResource BrushBorderSecondary}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Background="{StaticResource BrushTertiaryBackground}"
                        HorizontalAlignment="Stretch">
                    <StackPanel Spacing="16">
                        <TextBlock Text="{Binding FontSectionTitle}"
                                   FontSize="{DynamicResource FontSizeLabel}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushPrimaryText}" />

                        <!-- Font Size -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding FontSizeLabel}"
                                       FontSize="{DynamicResource FontSizeDefault}"
                                       Foreground="{StaticResource BrushSecondaryText}" />
                            <ComboBox ItemsSource="{Binding FontSizeOptions}"
                                      SelectedItem="{Binding SelectedFontSize, Mode=TwoWay}"
                                      Height="36"
                                      HorizontalAlignment="Stretch" />
                        </StackPanel>

                        <!-- Font Families (Side by Side) -->
                        <Grid ColumnDefinitions="*,16,*" RowDefinitions="Auto,12,Auto">
                            <StackPanel Grid.Column="0" Grid.Row="0" Spacing="8">
                                <TextBlock Text="{Binding UiFontLabel}"
                                           FontSize="{DynamicResource FontSizeDefault}"
                                           Foreground="{StaticResource BrushSecondaryText}" />
                                <ComboBox ItemsSource="{Binding AvailableUiFonts}"
                                          SelectedItem="{Binding SelectedUiFont, Mode=TwoWay}"
                                          IsTextSearchEnabled="True"
                                          Height="36"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Grid.Row="0" Spacing="8">
                                <TextBlock Text="{Binding HeadingFontLabel}"
                                           FontSize="{DynamicResource FontSizeDefault}"
                                           Foreground="{StaticResource BrushSecondaryText}" />
                                <ComboBox ItemsSource="{Binding AvailableUiFonts}"
                                          SelectedItem="{Binding SelectedHeadingFont, Mode=TwoWay}"
                                          IsTextSearchEnabled="True"
                                          Height="36"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="0" Grid.Row="2" Spacing="8">
                                <TextBlock Text="{Binding ButtonFontLabel}"
                                           FontSize="{DynamicResource FontSizeDefault}"
                                           Foreground="{StaticResource BrushSecondaryText}" />
                                <ComboBox ItemsSource="{Binding AvailableUiFonts}"
                                          SelectedItem="{Binding SelectedButtonFont, Mode=TwoWay}"
                                          IsTextSearchEnabled="True"
                                          Height="36"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                        </Grid>

                        <!-- Preview Section -->
                        <Border BorderBrush="{StaticResource BrushBorderSecondary}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12"
                                Background="{StaticResource BrushSecondaryBackground}"
                                Margin="0,16,0,0"
                                HorizontalAlignment="Stretch">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{Binding PreviewLabel}"
                                           FontSize="{DynamicResource FontSizeDefault}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushSecondaryText}" />

                                <Border Background="{StaticResource BrushTertiaryBackground}"
                                        BorderBrush="{StaticResource BrushBorderSecondary}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="12">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="{Binding PreviewHeadingText}"
                                                   FontFamily="{Binding PreviewHeadingFont}"
                                                   FontWeight="Bold"
                                                   FontSize="{Binding PreviewHeadingFontSize}"
                                                   Foreground="{StaticResource BrushPrimaryText}" />

                                        <TextBlock Text="{Binding PreviewUiText}"
                                                   FontFamily="{Binding PreviewUiFont}"
                                                   FontSize="{Binding PreviewFontSizeScale, Converter={StaticResource FontSizeScaleConverter}}"
                                                   Foreground="{StaticResource BrushSecondaryText}"
                                                   TextWrapping="Wrap" />

                                        <TextBox AcceptsReturn="True"
                                                 MinHeight="88"
                                                 VerticalContentAlignment="Top"
                                                 TextWrapping="Wrap"
                                                 FontFamily="{Binding PreviewUiFont}"
                                                 Watermark="{Binding [createguid.notes_watermark], Source={StaticResource Loc}}"
                                                 Classes="CompactInputTextBox" />

                                        <Button Content="{Binding PreviewButtonText}"
                                                HorizontalAlignment="Left"
                                                Classes="ActionButton AccentActionButton"
                                                FontFamily="{Binding PreviewButtonFont}"
                                                FontSize="{Binding PreviewButtonFontSize}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Button Content="{Binding ApplyFontSettingsLabel}"
                                Command="{Binding ApplyFontSettingsCommand}"
                                HorizontalAlignment="Right"
                                Classes="ActionButton AccentActionButton" />
                    </StackPanel>
                </Border>

                <!-- Danger Zone Card (macOS uninstall) -->
                <Border BorderBrush="{StaticResource BrushDangerDark}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Background="{StaticResource BrushTertiaryBackground}"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding IsUninstallSupported}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{Binding DangerZoneSectionTitle}"
                                   FontSize="{DynamicResource FontSizeLabel}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushDanger}" />

                        <!-- Initial state: uninstall prompt button -->
                        <Button Content="{Binding UninstallButtonLabel}"
                                Command="{Binding PromptUninstallCommand}"
                                Classes="ActionButton"
                                IsVisible="{Binding !IsPromptingUninstall}"
                                HorizontalAlignment="Left" />

                        <!-- Confirming state: warning + confirm/cancel -->
                        <StackPanel Spacing="12" IsVisible="{Binding IsPromptingUninstall}">
                            <TextBlock Text="{Binding UninstallWarningLabel}"
                                       FontSize="{DynamicResource FontSizeDefault}"
                                       Foreground="{StaticResource BrushSecondaryText}"
                                       TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="{Binding UninstallConfirmButtonLabel}"
                                        Command="{Binding ConfirmUninstallCommand}"
                                        Classes="ActionButton DangerActionButton" />
                                <Button Content="{Binding UninstallCancelButtonLabel}"
                                        Command="{Binding CancelUninstallCommand}"
                                        Classes="ActionButton" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>

