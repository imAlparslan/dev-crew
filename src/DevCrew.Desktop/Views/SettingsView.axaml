<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DevCrew.Desktop.ViewModels"
             xmlns:conv="using:DevCrew.Desktop.Converters"
             x:Class="DevCrew.Desktop.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
    <UserControl.Resources>
        <conv:FontSizeScaleConverter x:Key="FontSizeScaleConverter" />
    </UserControl.Resources>
    <ScrollViewer>
        <Border Padding="{DynamicResource ResponsivePaddingMedium}" Background="{StaticResource BrushSecondaryBackground}">
            <StackPanel Spacing="24" HorizontalAlignment="Stretch">
                <TextBlock Text="{Binding Title}"
                           FontSize="{DynamicResource FontSizeHeading}"
                           FontWeight="Bold"
                           Foreground="{StaticResource BrushPrimaryText}" />

                <!-- Application Language Setting Card -->
                <Border BorderBrush="{StaticResource BrushBorderSecondary}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Background="{StaticResource BrushTertiaryBackground}"
                        HorizontalAlignment="Stretch">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding LanguageLabel}"
                                   FontSize="{DynamicResource FontSizeLabel}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushPrimaryText}" />
                        <ComboBox ItemsSource="{Binding SupportedLanguages}"
                                  SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                                  Height="36">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Font Settings Card -->
                <Border BorderBrush="{StaticResource BrushBorderSecondary}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Background="{StaticResource BrushTertiaryBackground}"
                        HorizontalAlignment="Stretch">
                    <StackPanel Spacing="16">
                        <TextBlock Text="{Binding FontSectionTitle}"
                                   FontSize="{DynamicResource FontSizeLabel}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushPrimaryText}" />

                        <!-- Font Size -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding FontSizeLabel}"
                                       FontSize="{DynamicResource FontSizeDefault}"
                                       Foreground="{StaticResource BrushSecondaryText}" />
                            <ComboBox ItemsSource="{Binding FontSizeOptions}"
                                      SelectedItem="{Binding SelectedFontSize, Mode=TwoWay}"
                                      Height="36"
                                      HorizontalAlignment="Stretch" />
                        </StackPanel>

                        <!-- UI Font -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding UiFontLabel}"
                                       FontSize="{DynamicResource FontSizeDefault}"
                                       Foreground="{StaticResource BrushSecondaryText}" />
                            <ComboBox ItemsSource="{Binding AvailableUiFonts}"
                                      SelectedItem="{Binding SelectedUiFont, Mode=TwoWay}"
                                      Height="36"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- Preview Section -->
                        <Border BorderBrush="{StaticResource BrushBorderSecondary}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12"
                                Background="{StaticResource BrushSecondaryBackground}"
                                Margin="0,16,0,0"
                                HorizontalAlignment="Stretch">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{Binding PreviewLabel}"
                                           FontSize="{DynamicResource FontSizeDefault}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushSecondaryText}" />

                                <Grid ColumnDefinitions="*,16,*" RowDefinitions="Auto">
                                    <!-- UI Font Preview -->
                                    <StackPanel Grid.Column="0" Spacing="6">
                                        <TextBlock Text="{Binding UiFontLabel}"
                                                   FontSize="{DynamicResource FontSizeSmall}"
                                                   Foreground="{StaticResource BrushTertiaryText}" />
                                        <Border Background="{StaticResource BrushTertiaryBackground}"
                                                CornerRadius="4"
                                                Padding="8">
                                            <TextBlock Text="{Binding PreviewUiText}"
                                                       FontFamily="{Binding PreviewUiFontFamily}"
                                                       FontSize="{Binding PreviewFontSizeScale, Converter={StaticResource FontSizeScaleConverter}}"
                                                       Foreground="{StaticResource BrushPrimaryText}" />
                                        </Border>
                                    </StackPanel>

    
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>

