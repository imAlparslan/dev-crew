<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DevCrew.Desktop.ViewModels"
             xmlns:controls="using:DevCrew.Desktop.Controls"
             x:Class="DevCrew.Desktop.Views.Base64EncoderView"
             x:DataType="vm:Base64EncoderViewModel">

    <ScrollViewer>
        <Border Padding="{DynamicResource ResponsivePaddingMedium}" Background="{StaticResource BrushSecondaryBackground}">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto" HorizontalAlignment="Stretch">
                <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
                    <TextBlock Text="{Binding [base64encoder.title], Source={StaticResource Loc}}"
                               FontSize="{DynamicResource FontSizeHeading}"
                               FontFamily="{DynamicResource FontHeading}"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrushPrimaryText}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <Border Grid.Row="1"
                        Background="{StaticResource BrushTertiaryBackground}"
                        BorderBrush="{StaticResource BrushBorderSecondary}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        DragDrop.AllowDrop="True"
                        x:Name="InputBorder">
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="{Binding [base64encoder.input_title], Source={StaticResource Loc}}"
                                   FontSize="{DynamicResource FontSizeLabel}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushSecondaryText}"
                                   VerticalAlignment="Center" />

                        <Button Grid.Row="0"
                            Grid.Column="1"
                            Content="{Binding [base64encoder.browse], Source={StaticResource Loc}}"
                                Command="{Binding BrowseFileCommand}"
                                Padding="10,6"
                                FontWeight="SemiBold"
                                Classes="ActionButton PrimaryActionButton"
                                ToolTip.Tip="{Binding [base64encoder.browse_tooltip], Source={StaticResource Loc}}" />

                        <TextBox Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 Text="{Binding SelectedFileDisplayName}"
                                 IsReadOnly="True"
                                 MinHeight="80"
                                 Margin="0,10,0,0"
                                 Padding="8"
                                 Classes="MonospaceInputTextBox"
                                 FontFamily="{DynamicResource FontMonospace}"
                                 FontSize="{DynamicResource FontSizeSmall}"
                                 VerticalContentAlignment="Center"
                                 TextWrapping="Wrap"
                                 Watermark="{Binding [base64encoder.input_watermark], Source={StaticResource Loc}}" />
                    </Grid>
                </Border>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,16">
                    <Button Content="{Binding [base64encoder.encode], Source={StaticResource Loc}}"
                            Command="{Binding EncodeCommand}"
                            IsEnabled="{Binding HasSelectedFile}"
                            Classes="ActionButton PrimaryActionButton"
                            FontWeight="SemiBold"
                            ToolTip.Tip="{Binding [base64encoder.encode_tooltip], Source={StaticResource Loc}}" />
                </StackPanel>

                <Border Grid.Row="3"
                        Background="{StaticResource BrushTertiaryBackground}"
                        BorderBrush="{StaticResource BrushBorderSecondary}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,8">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding [base64encoder.output_title], Source={StaticResource Loc}}"
                                       FontSize="{DynamicResource FontSizeLabel}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushSecondaryText}"
                                       VerticalAlignment="Center" />

                                <Button Grid.Column="1"
                                    Content="{Binding [base64encoder.show_all], Source={StaticResource Loc}}"
                                    Command="{Binding ShowFullOutputCommand}"
                                    IsVisible="{Binding CanShowFullOutput}"
                                    Margin="0,0,8,0"
                                    Padding="10,6"
                                    FontWeight="SemiBold"
                                    Classes="ActionButton NeutralActionButton"
                                    ToolTip.Tip="{Binding [base64encoder.show_all_tooltip], Source={StaticResource Loc}}" />

                            <controls:CopyActionButton Grid.Column="2"
                                                       Command="{Binding CopyOutputCommand}"
                                                       IsEnabled="{Binding HasOutput}"
                                                       Width="32"
                                                       Height="32"
                                                       ToolTipText="{Binding [base64encoder.copy_tooltip], Source={StaticResource Loc}}"
                                                       Cursor="Hand" />
                        </Grid>

                        <Border Grid.Row="1"
                                Padding="8"
                                CornerRadius="4"
                                Margin="0,0,0,8"
                                IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding IsError, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#5F2D2D|#2D5F2E'}" Opacity="0.2" />
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{Binding IsError, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#F44336|#4CAF50'}" />
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>

                            <TextBlock Text="{Binding StatusMessage}"
                                       FontSize="{DynamicResource FontSizeDefault}"
                                       FontWeight="Medium"
                                       TextWrapping="Wrap">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="{Binding IsError, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#F44336|#4CAF50'}" />
                                </TextBlock.Foreground>
                            </TextBlock>
                        </Border>

                        <TextBox Grid.Row="2"
                                 Text="{Binding OutputBase64}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 IsReadOnly="True"
                                 MinHeight="220"
                                 MaxHeight="520"
                                 Padding="8"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"
                                 VerticalContentAlignment="Top"
                                 Classes="MonospaceInputTextBox"
                                 FontFamily="{DynamicResource FontMonospace}"
                                 FontSize="{DynamicResource FontSizeSmall}"
                                 Watermark="{Binding [base64encoder.output_watermark], Source={StaticResource Loc}}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </ScrollViewer>
</UserControl>