<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DevCrew.Desktop.ViewModels"
             x:Class="DevCrew.Desktop.Views.Base64EncoderView"
             x:DataType="vm:Base64EncoderViewModel">

    <ScrollViewer>
        <Border Padding="{DynamicResource ResponsivePaddingMedium}" Background="{StaticResource BrushSecondaryBackground}">
            <Grid RowDefinitions="Auto,Auto,Auto,*" HorizontalAlignment="Stretch">
                <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
                    <TextBlock Text="Base64 Encoder"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrushPrimaryText}"
                               HorizontalAlignment="Center" />

                    <TextBlock Text="Dosyanizi yukleyin, Encode ile Base64 ciktisini olusturun"
                               FontSize="14"
                               Foreground="{StaticResource BrushSecondaryText}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Row="1"
                        Background="{StaticResource BrushTertiaryBackground}"
                        BorderBrush="{StaticResource BrushBorderSecondary}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        DragDrop.AllowDrop="True"
                        x:Name="InputBorder">
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="Input Dosya"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushSecondaryText}"
                                   VerticalAlignment="Center" />

                        <Button Grid.Row="0"
                                Grid.Column="1"
                                Content="Browse"
                                Command="{Binding BrowseFileCommand}"
                                Padding="10,6"
                                FontWeight="SemiBold"
                                Classes="ActionButton PrimaryActionButton"
                                ToolTip.Tip="Bilgisayardan dosya sec" />

                        <TextBox Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 Text="{Binding SelectedFileDisplayName}"
                                 IsReadOnly="True"
                                 MinHeight="80"
                                 Margin="0,10,0,0"
                                 Padding="8"
                                 Classes="MonospaceInputTextBox"
                                 FontFamily="{StaticResource FontMonospace}"
                                 FontSize="{StaticResource FontSizeSmall}"
                                 VerticalContentAlignment="Center"
                                 TextWrapping="Wrap"
                                 Watermark="Dosyayi surukleyip birakin veya Browse ile secin" />
                    </Grid>
                </Border>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,16">
                    <Button Content="Encode"
                            Command="{Binding EncodeCommand}"
                            IsEnabled="{Binding HasSelectedFile}"
                            Classes="ActionButton PrimaryActionButton"
                            FontWeight="SemiBold"
                            ToolTip.Tip="Secilen dosyayi Base64 formatina cevir" />
                </StackPanel>

                <Border Grid.Row="3"
                        Background="{StaticResource BrushTertiaryBackground}"
                        BorderBrush="{StaticResource BrushBorderSecondary}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                            <TextBlock Grid.Column="0"
                                       Text="Base64 Output"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushSecondaryText}"
                                       VerticalAlignment="Center" />

                            <Button Grid.Column="1"
                                    Command="{Binding CopyOutputCommand}"
                                    IsEnabled="{Binding HasOutput}"
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    ToolTip.Tip="Ciktiyi kopyala"
                                    Cursor="Hand">
                                <TextBlock Text="📋"
                                           FontSize="16"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                        </Grid>

                        <Border Grid.Row="1"
                                Padding="8"
                                CornerRadius="4"
                                Margin="0,0,0,8"
                                IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding IsError, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#5F2D2D|#2D5F2E'}" Opacity="0.2" />
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{Binding IsError, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#F44336|#4CAF50'}" />
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>

                            <TextBlock Text="{Binding StatusMessage}"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       TextWrapping="Wrap">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="{Binding IsError, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#F44336|#4CAF50'}" />
                                </TextBlock.Foreground>
                            </TextBlock>
                        </Border>

                        <TextBox Grid.Row="2"
                                 Text="{Binding OutputBase64}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 IsReadOnly="True"
                                 MinHeight="220"
                                 MaxHeight="520"
                                 Padding="8"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"
                                 VerticalContentAlignment="Top"
                                 Classes="MonospaceInputTextBox"
                                 FontFamily="{StaticResource FontMonospace}"
                                 FontSize="{StaticResource FontSizeSmall}"
                                 Watermark="Encode sonucu burada gorunecek"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </ScrollViewer>
</UserControl>